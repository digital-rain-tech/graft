<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
    xmlns:jr="http://jasperreports.sourceforge.net/jasperreports/components"
    name="table_component" pageWidth="595" pageHeight="842"
    columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
    <subDataset name="rows">
        <field name="col_a" class="java.lang.String"/>
    </subDataset>
    <field name="header" class="java.lang.String"/>
    <detail>
        <band height="80">
            <componentElement>
                <reportElement x="0" y="0" width="555" height="60"/>
                <jr:table xmlns:jr="http://jasperreports.sourceforge.net/jasperreports/components">
                    <datasetRun subDataset="rows"/>
                    <jr:column width="100">
                        <jr:detailCell height="20">
                            <textField>
                                <reportElement x="0" y="0" width="100" height="20"/>
                                <textFieldExpression><![CDATA[$F{col_a}]]></textFieldExpression>
                            </textField>
                        </jr:detailCell>
                    </jr:column>
                </jr:table>
            </componentElement>
        </band>
    </detail>
</jasperReport>
