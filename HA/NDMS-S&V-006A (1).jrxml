	<subDataset name="AL" uuid="6312e51d-09d0-4ccc-b570-4405789c9146">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Dev (EMC01)"/>
		<parameter name="REPORT_YEAR" class="java.lang.String"/>
		<parameter name="REPORT_MONTH" class="java.lang.String"/>
		<parameter name="STATUS" class="java.lang.String"/>
		<queryString language="SQL">
			<![CDATA[select 
HSE_RGN_CODE,
HSE_EST_ENG_NAME,
HSE_STCK_MAIN_CODE_ADDR,
SUM(HSE_STCK_LES_AREA) AS Approved_Letting_Area
from
(
SELECT HSE_RGN_CODE,HSE_EST_ENG_NAME,
CASE WHEN HSE_STCK_DSGN_TRD_CODE = 'CO04' OR HSE_STCK_DSGN_TRD_CODE = 'RFDA' OR HSE_STCK_DSGN_TRD_CODE = 'SVPB' THEN
CONCAT(HSE_STCK_MAIN_CODE_ADDR,'*')
ELSE
HSE_STCK_MAIN_CODE_ADDR
END AS HSE_STCK_MAIN_CODE_ADDR,
HSE_STCK_LES_AREA
FROM CIS_RPT_SV_ACTUAL_CRITERIA_V
WHERE COMMITED_TYPE LIKE 'E_Approved Letting' AND
SYS_RPT_YEAR = $P{REPORT_YEAR} AND
SYS_RPT_MTH = $P{REPORT_MONTH} AND
(($P{STATUS} = 'P' and CIS_DSBD_APRV_STS_CODE <> 'A') OR ($P{STATUS} = 'C' AND CIS_DSBD_APRV_STS_CODE = 'A'))
) R6_Approved_Lettings
GROUP BY HSE_RGN_CODE, HSE_EST_ENG_NAME,HSE_STCK_MAIN_CODE_ADDR
ORDER BY HSE_RGN_CODE ASC, HSE_EST_ENG_NAME ASC]]>
		</queryString>
		<field name="HSE_RGN_CODE" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="HSE_RGN_CODE"/>
		</field>
		<field name="HSE_EST_ENG_NAME" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="HSE_EST_ENG_NAME"/>
		</field>
		<field name="HSE_STCK_MAIN_CODE_ADDR" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="HSE_STCK_MAIN_CODE_ADDR"/>
		</field>
		<field name="APPROVED_LETTING_AREA" class="java.math.BigDecimal">
			<property name="com.jaspersoft.studio.field.label" value="APPROVED_LETTING_AREA"/>
		</field>
		<variable name="SUM_APPROVED_LETTING_AREA" class="java.lang.Double" resetType="Column" calculation="Sum">
			<variableExpression><![CDATA[$F{APPROVED_LETTING_AREA}]]></variableExpression>
		</variable>
		<variable name="SUM_APPROVED_LETTING_AREA2" class="java.lang.Double" calculation="Sum">
			<variableExpression><![CDATA[$F{APPROVED_LETTING_AREA}]]></variableExpression>
		</variable>
	</subDataset>
	<subDataset name="TTBC" whenResourceMissingType="Key" uuid="145a16db-6be5-4ae3-97ea-45066d0a6f97">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
