        <PrivilegeControl/>
        <Expand/>
      </C>
      <C c="2" r="223" cs="11" rs="20">
        <O><![CDATA[No matter whether Landlord demanded formally or not, to avoid
any levy of interest as stipulated in the Tenancy Agreement/
Licence, please pay within 14 days of the due date.]]></O>
        <PrivilegeControl/>
        <Expand/>
      </C>
      <C c="0" r="224" rs="9">
        <O><![CDATA[2)]]></O>
        <PrivilegeControl/>
