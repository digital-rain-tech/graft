        <O><![CDATA[4)]]></O>
        <PrivilegeControl/>
        <Expand/>
      </C>
      <C c="2" r="251" cs="11" rs="14">
        <O><![CDATA[If you have paid the rent due for payment shown in the monthly
statement or you have any enquiries on the monthly statement,
please contact our estate office or property management
companies.]]></O>
        <PrivilegeControl/>
        <Expand/>
      </C>
