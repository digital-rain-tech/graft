        <Expand/>
      </C>
      <C c="2" r="328" cs="11" rs="15">
        <O><![CDATA[Simply present the monthly statement when making payment.
Please check carefully and ensure details printed on the receipt
are correct. Retain the receipt or make a photocopy of it, if
required, and the monthly statement as the record of payment for
checking.]]></O>
        <PrivilegeControl/>
        <Expand/>
      </C>
      <C c="2" r="328" cs="11" rs="7">
        <O><![CDATA[The number of daily payment per tenant code is up to 3.]]></O>
        <PrivilegeControl/>
        <Expand/>
      </C>
      <C c="0" r="330" rs="6">
        <O><![CDATA[4)]]></O>
        <PrivilegeControl/>
        <Expand/>
      </C>
      <C c="1" r="330" cs="11" rs="6">
        <O><![CDATA[每個租戶號碼，一天內最多只能繳交3次。]]></O>
        <PrivilegeControl/>
        <Expand/>
      </C>
