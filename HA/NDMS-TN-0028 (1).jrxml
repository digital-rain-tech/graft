			<staticText>
				<reportElement x="43" y="124" width="15" height="15" uuid="6354c0bf-539f-4f1b-9f69-6df69ab746c1">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(5)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="124" width="465" height="62" uuid="5884b55d-da47-4a80-b27b-cd6103eec61f">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[To keep the interior of the said shop including the interior decoration and all the Landlord's fixtures and fittings in good and tenantable repair and condition and thoroughly clean and tidy throughout the tenancy (fair wear and tear excepted) and from time to time as considered necessary by the Landlord to paint with colourwash those parts of
the interior of the said shop which were at the commencement of the tenancy so painted in the same colour as existing or such other colour as may be approved by the Landlord.]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="190" width="465" height="83" uuid="392683a0-1658-4306-bf38-dd4c2dba832d">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[To use the Landlord's fixtures and fittings and the sewers and drains serving the said shop in a proper and careful manner and to pay the Landlord on demand the cost incurred in repair or replacement of any of the said items
arising otherwise than through fair wear and tear and the cost of clearing any drains or sewers choked or stopped
up by reason of careless use by the Tenant or members of his family, his employees or licensees; provided that if
the Tenant shall effect any of the aforesaid repairs or replacements or clearance of sewers or drains without the
prior consent of the Landlord he shall be responsible for any costs incurred by the Landlord in remedying any such repairs or replacements or clearances effected by the Tenant which the Landlord considers unsatisfactory.]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="190" width="15" height="15" uuid="0d828443-edd0-416d-b9f5-c0ec99c04935">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(6)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="278" width="465" height="25" uuid="0dce0048-a94d-49b6-96e1-43ae3b0a31b1">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[To replace at his own expense any glass in any doors or windows of the said shop that may become broken from whatever cause, during the tenancy.]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="278" width="15" height="15" uuid="357593b7-f7ba-4887-9906-071506795941">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(7)]]></text>
			</staticText>
			<staticText>
				<reportElement x="25" y="787" width="115" height="12" uuid="f790241e-7ca2-4279-bc26-e0d877224ba8">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="8.5"/>
				</textElement>
				<text><![CDATA[* Delete if inapplicable ]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="308" width="465" height="15" uuid="fd16c12a-8a57-4c20-8aba-a62a2065bca0">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[To take all reasonable precautions to protect the interior of the said shop against damage by storm or typhoon.]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="308" width="15" height="15" uuid="60f028b2-3053-44aa-a2a9-6ebceb0c4952">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(8)]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="328" width="15" height="15" uuid="85f9f172-3e31-4ad2-aa04-a166d63565a7">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(9)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="328" width="465" height="38" uuid="0faed716-587d-41d2-99a9-d8af98430c0e">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[Not to make any alterations whatsoever to the said shop or any electrical or air-conditioning installations therein or to install any fixture partition or other erection therein, or to remove any of the Landlord's fixtures or fittings
without the previous consent in writing of the Landlord.]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="371" width="465" height="38" uuid="a6bfd470-b5e6-493c-9cca-80c3af6466cd">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[To indemnify the Landlord against all actions costs claims and demands made upon or against the Landlord in respect of damage to the person or property of any person caused by or through or in any way due to the overflow
of water or drainage from the said shop or any part thereof.]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="371" width="17" height="15" uuid="363d42f7-f8fe-4f04-939f-c897a0a25205">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(10)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="415" width="465" height="12" uuid="1dcff84d-f536-45ae-a0b5-667943a1019d">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified" markup="html">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[Not to carry on or permit or suffer to be carried on in or upon the said shop or any part thereof any trade profession<br>a]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="415" width="17" height="15" uuid="8e6d3dea-fecb-4487-8eb6-2c16f3380fdf">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(11)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="462" width="465" height="47" uuid="389ae877-bdd2-4e09-b777-2e4f7f9c2d9f">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[Not to conduct or permit any auction sale of things or properties of any kind to take place on the said shop
provided that this provision shall not preclude the conduct of genuine periodic seasonal or promotional sales of things or properties that are relating to the trade profession or business or activities permitted under the Clause
II(11).]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="462" width="17" height="15" uuid="5eed60d6-ddb1-4d7b-8222-13827e5b6fb3">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(12)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="515" width="465" height="38" uuid="fe90df55-1749-47f9-a9b4-de108f5a3de0">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[At his own expense to install a shop front (including the shop sign, shop window and window frame and door) and to fit up the said shop with furniture fixtures and fittings to the requirements and satisfaction in all respects of the Landlord and other authority concerned.]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="515" width="17" height="15" uuid="fd23b34e-fd79-4a9d-8ccb-e126fdac91f4">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(13)]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="560" width="17" height="15" uuid="9f3ac03c-f592-4506-ad78-745d67c3e20c">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(14)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="560" width="465" height="27" uuid="daf13795-39d7-4ae6-86fb-dbec814190bd">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[To install and keep lit at the Tenant’s own expense a shop sign of the said shop during the opening hours of the
shop and when the common areas of the shopping centre are open to the public and for the better observance.]]></text>
			</staticText>
			<staticText>
				<reportElement x="28" y="560" width="15" height="15" uuid="4256973c-e937-43f7-930d-57b8891d26e5">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Right">
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[*]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="593" width="465" height="50" uuid="f63f2a48-0433-498a-a4a4-0add95c3199a">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[At all times during the tenancy hereby created to observe and perform the provisions of all laws, ordinances and regulations and all by-laws directions and orders of other authority and to obtain from the appropriate authority or authorities at his own expense all licences and permits that may be required in connection with the business carried on in the said shop.]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="593" width="17" height="15" uuid="882db276-1c61-4968-8dd8-1d7af36dfa91">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(15)]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="649" width="17" height="15" uuid="bcc2b0ad-1806-4679-acf7-8c4bd0d99a69">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(16)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="649" width="465" height="27" uuid="ea0b995f-65dd-461b-a19e-e3ebf23f5bdb">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[If the Tenant shall be the sole proprietor of the business of the said shop not to admit any partner during the tenancy hereby created and if the Tenant shall consist of partners not to admit any new partner during the said tenancy.]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="681" width="465" height="27" uuid="675961ff-f3fc-4480-beb2-519dea3d1d89">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[Not to permit or suffer any person to remain on the said shop between the hours of 11:00 p.m. and 7:00 a.m. except with the prior approval of the Landlord.]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="681" width="17" height="15" uuid="892f9f63-4951-4049-8088-c74147bc2d01">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(17)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="715" width="465" height="15" uuid="434cd809-4c11-41c0-a78c-01560af628d8">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[Not to use or cause or permit the said shop or any part thereof to be used for any unlawful or immoral purpose.]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="715" width="17" height="15" uuid="3dc59daf-9f3c-4ace-a834-7a9317dc7f91">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(18)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="737" width="465" height="50" uuid="4a6da1c1-cf9f-4fba-bc03-d8973bbd6001">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[Not to cause or permit any touting or soliciting for business or distribution of any pamphlets notices or advertising materials outside the said shop or anywhere within the common area of the *shopping centre/estate where the said shop is situated by any of the Tenant, his servants, employees, invitees, agents, contractors or licensees without the prior written consent of the Landlord.]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="737" width="17" height="15" uuid="d20f230e-0eaa-40d5-aefb-5ca8054eca0f">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(19)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="427" width="217" height="12" uuid="6ec3da26-4f5e-4e48-8337-fc7868fdd99e">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified" markup="html">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[or business or activities whatsoever other than that of]]></text>
			</staticText>
			<textField textAdjust="ScaleFont" isBlankWhenNull="true">
				<reportElement x="281" y="427" width="192" height="12" uuid="f5fee5d5-4569-4183-bc32-491da8f52588">
