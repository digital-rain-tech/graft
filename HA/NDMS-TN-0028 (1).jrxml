	<field name="DEPOSIT_AMT" class="java.math.BigDecimal"/>
	<field name="CURRENCY_DEPOSIT_TEXT" class="java.lang.String"/>
	<field name="FIRST_RENT" class="java.math.BigDecimal"/>
	<field name="CURRENCY_FIRST_RENT_TEXT" class="java.lang.String"/>
	<field name="NO_OF_RENTFREE" class="java.lang.Integer"/>
	<field name="FIRST_RENT_TEXT" class="java.lang.String"/>
