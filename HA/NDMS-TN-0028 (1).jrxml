			</staticText>
			<staticText>
				<reportElement x="42" y="23" width="17" height="15" uuid="54a63f44-aade-4466-99cc-5210c49c8792">
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
					<property name="com.jaspersoft.studio.unit.x" value="px"/>
				</reportElement>
				<textElement>
