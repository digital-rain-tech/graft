			<textField>
				<reportElement x="333" y="32" width="196" height="13" uuid="5c3510e6-7c46-485c-b09a-cb16b8512d1f">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Right" markup="html">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<textFieldExpression><![CDATA[")之空氣調節費，作為額外租金。首期空氣調"]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="65" y="45" width="464" height="48" uuid="5bf59dc6-d93e-49c1-bb02-5b85b3377ad7">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified" markup="html">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<textFieldExpression><![CDATA["節費須於業主指定之日期繳交，此後須於每月之首日上期繳交。倘在租賃期內，冷氣設施之操作成本上升，則業主有權增加空氣調節費，但事前會預先一個月以書面通知承租人，此後承租人即須繳付新訂之空氣調節費，以代替本租約現訂之收費。"]]></textFieldExpression>
			</textField>
		</band>
		<band height="799">
			<staticText>
				<reportElement x="242" y="1" width="76" height="14" forecolor="#808080" uuid="b5cfbb88-2278-4c0a-9c53-19f42bf7d474"/>
				<textElement textAlignment="Center"/>
				<text><![CDATA[3]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="98" width="465" height="105" uuid="c77c68ab-72c8-40a2-a87c-9ff133aa1443">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[Not to store or cause or permit to be stored in the said shop or any part thereof any arms, ammunition, gunpowder, kerosene, petrol or any explosive or combustible material or substance whatsoever except that the Tenant may
keep therein not more than two containers of liquefied petroleum gas or if the said shop is not situated within the
Sha Tin Fuel Restriction Area as defined under the Air Pollution Control (Fuel Restriction) Regulations Cap. 311I, the Tenant may keep a reasonable quantity of kerosene (not exceeding twenty litres at any one time) for the
purposes of domestic cooking, and that Tenants holding current firearms licences issued by the Commissioner of Police may keep the arms to which the licence relates together with a reasonable quantity of suitable ammunition subject to the Landlord's agent being informed of the existence of such licence and of its renewal where such takes place.]]></text>
			</staticText>
			<staticText>
				<reportElement x="42" y="98" width="17" height="15" uuid="d242cee9-6684-4d53-a3ad-3011d526548c">
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(22)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="208" width="465" height="85" uuid="635c5768-093d-435a-a603-afc39ada99d6">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[Not to use the said shop for the manufacture of goods or merchandise or for the storage of goods or merchandise other than stock reasonably required in connection with the Tenant’s business carried on therein nor to keep or
store or cause or permit or suffer to be kept or stored any hazardous or dangerous goods within the meaning of the Dangerous Goods Ordinance and the regulations thereunder or any Statutory modification or re-enactment thereof provided that Tenant of the said shop let for the purposes requiring the heating of water or cooking of food in bulk may be permitted to store the approved fuel subject to any direction of the Landlord or of any competent authority with regard to the manner of storage or amount to be stored.]]></text>
			</staticText>
			<staticText>
				<reportElement x="42" y="208" width="17" height="15" uuid="e4eb89a7-0907-459d-8bce-9e660f8f6814">
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(23)]]></text>
			</staticText>
			<staticText>
				<reportElement x="42" y="296" width="17" height="15" uuid="8e47eaeb-9b24-4b75-a598-1a63addbfa9b">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(24)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="296" width="465" height="38" uuid="0b87bb47-a376-48f6-b9f0-1b94c30e36d2">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[Not to leave or cause or permit to be left any furniture boxes goods articles or rubbish in the entrance hall or on the stairways or landings or on any of the passage ways or lifts of the building of which the shop forms part or to
cause any obstruction whatsoever thereto or to the common areas or pavement pertaining to the said shop.]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="338" width="465" height="25" uuid="fd79d12a-172d-417b-81a8-8879354bb454">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[Not to use any area outside the said shop for any purpose such as storage or display of goods and not to erect any structure or roof on or over any such area. ]]></text>
			</staticText>
			<staticText>
				<reportElement x="42" y="338" width="17" height="15" uuid="3c9f1c8c-a6e1-407a-9b85-11f6850daac1">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(25)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="368" width="465" height="38" uuid="5570dbd1-2e7c-4457-873c-e28723302389">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[Not to affix or cause or permit any poster signboard or advertising matter of any kind to be affixed to any part of
the exterior of the said shop except such as has been approved by the Landlord in writing and then only in a place
and in a manner approved by the Landlord. ]]></text>
			</staticText>
			<staticText>
				<reportElement x="42" y="368" width="17" height="15" uuid="facb3ad1-f2b5-47f1-a5f9-974f634018cf">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(26)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="411" width="465" height="83" uuid="568ecb88-51a8-4408-8679-d9f0084db416">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[That all cooking of food and heating of liquids in the said shop shall be done by means of an electric stove or other electric appliance or by a gas stove or other appliance using liquefied petroleum gas as a fuel (provided that in the latter case the installation is carried out by a contractor approved by the Landlord) and not to do or cause or permit any cooking of food or heating of liquids by any method involving the use of conventional liquid fuel or
conventional solid fuel as defined under the Air Pollution Control (Fuel Restriction) Regulations Cap. 311I
provided that if the said shop is not situated within the Sha Tin Fuel Restriction Area as defined under the Air Pollution Control (Fuel Restriction) Regulations Cap. 311I, other appliance using kerosene as a fuel can be used.]]></text>
			</staticText>
			<staticText>
				<reportElement x="42" y="411" width="17" height="15" uuid="2af2eb98-9d39-405f-9e09-a29190f39d5b">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(27)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="500" width="465" height="15" uuid="b614596f-7248-4d3c-ae92-87f24478ee07">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[Not to keep any animal bird or livestock of any description in the said shop or any part thereof.]]></text>
			</staticText>
			<staticText>
				<reportElement x="42" y="500" width="17" height="15" uuid="9f335735-5eff-4d1a-a3d8-dccd2b49c04d">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(28)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="521" width="465" height="40" uuid="fd0e0548-bca3-484d-9363-e5921895e365">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[Not to transfer and assign the Tenant’s rights and obligations of this Agreement, sublet, licence, share or otherwise part with possession of the said shop or any part thereof to any third party without the prior written consent of the Landlord.]]></text>
			</staticText>
			<staticText>
				<reportElement x="42" y="521" width="17" height="15" uuid="11d9bf3e-09d6-42f9-8d8e-c8dafbc3c8c4">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(29)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="565" width="465" height="40" uuid="7cab32fc-7b23-4a40-83bd-8b18953b3251">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[To permit the Landlord and his agents and all persons authorized by him at reasonable hours right of access to go
pass or repass and to enter and view the said shop and to take an inventory of the fixtures and fittings therein and
to do any repair or work for which the Landlord is liable hereunder. ]]></text>
			</staticText>
			<staticText>
				<reportElement x="42" y="565" width="17" height="15" uuid="18846fd7-3ccf-45f3-815d-e674351b6a2f">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(30)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="609" width="465" height="24" uuid="666280c9-5cd3-4f6a-a3a7-abbd390fdedc">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified" markup="html">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[To commence operation of the business specified in Clause II (11) within<u>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</u> months from the date of commencement of this agreement.]]></text>
			</staticText>
			<staticText>
				<reportElement x="42" y="609" width="17" height="15" uuid="5b64a68a-1c6b-4f81-b7f2-e216d49d8224">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(31)]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="23" width="17" height="15" uuid="8ae9ba42-61f7-4324-9821-896bc80ebabe">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.x" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(20)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="23" width="465" height="27" uuid="213a2d7d-7310-45ad-8b8f-b0a143989712">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
					<property name="com.jaspersoft.studio.unit.x" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[Not to do or cause or permit to be done in or on the said shop or approaches thereto anything that may be or become a nuisance or annoyance to the Landlord or the tenants or occupiers of other property in the neighbourhood.]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="56" width="17" height="15" uuid="b697f595-18f8-45fd-9a93-84affd3b12ab">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
					<property name="com.jaspersoft.studio.unit.x" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(21)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="56" width="465" height="35" uuid="a848b40a-3ce9-480b-a7d9-6c1e91a23b90">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
					<property name="com.jaspersoft.studio.unit.x" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[Not to cause or permit to be caused any nuisance or any noise which is a source of annoyance by any means whatsoever, or by the issue of any other noise or disturbance in the said shop between the hours of eleven in the evening and seven in the morning.]]></text>
			</staticText>
		</band>
		<band height="800">
			<staticText>
				<reportElement x="242" y="1" width="76" height="14" forecolor="#808080" uuid="47ee0877-1ed2-46be-b9b8-a41b8a5915de"/>
				<textElement textAlignment="Center"/>
				<text><![CDATA[第三頁]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="110" width="17" height="15" uuid="4bc92019-51f4-4054-bbfc-3d9ff664615e">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(22)]]></text>
			</staticText>
			<staticText>
				<reportElement x="65" y="110" width="464" height="66" uuid="14995372-d252-4f5c-b30a-68a7cd55f7f0">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[承租人不得在該舖位任何部分儲藏，或促使或容許他人儲藏任何槍械、彈藥、炸藥、火水、電油、任何爆炸品或易燃物品，但可儲存不超過兩罐石油氣，又或該舖位並非位於香港法例第311I章空氣污染管制(燃料限制)規例所指之沙田燃料限制區內，則可儲存合理數量火水(每次儲量不得超過二十公升)，作煮食用途。承租人倘持有警務處處長發給之有效軍火牌照者，則可存放該牌照所核准之槍械及數量合理之適用彈藥，但承租人必須將其持有牌照及換領新牌照等事項通知業主之代理人。]]></text>
			</staticText>
			<staticText>
				<reportElement x="65" y="190" width="464" height="68" uuid="f5922523-cddb-4603-b017-2cf67991d290">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[不得使用該舖位製造貨品或商品，或貯存貨品或商品(承租人在該舖位經營業務合理所需的存貨除外)，亦不得存放或貯存，或促使、容許或容受他人存放或貯存任何危險物品，或《危險品條例》或該條例下的各規例或法例規定有關該條例的任何修改或重訂條文所界定的危險品；如該舖位的出租用途需要大量燒水或烹調食物，其承租人可獲准貯存經許可的燃料，但貯存方式和貯存量均須符合業主或任何主管機關的指示。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="190" width="17" height="15" uuid="c79d9105-e913-44a0-bc11-eb8e7000379a">
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(23)]]></text>
			</staticText>
			<staticText>
				<reportElement x="65" y="269" width="464" height="31" uuid="cbfe97ac-483e-4595-a1ea-4e2de115980e">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[不得在該舖位所屬大廈之入口、樓梯、梯台、任何通道或升降機留下、促使或容許他人留下任何傢具、箱
匣、貨物、雜物、垃圾，或將各該地方、公用地方及該舖位周邊之行人道阻塞。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="269" width="17" height="15" uuid="7d059ee4-4dae-404c-a4b7-7c7d94dfaa1c">
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(24)]]></text>
			</staticText>
			<staticText>
				<reportElement x="65" y="311" width="464" height="31" uuid="8323e970-2954-4a39-a79c-57788c17fe4d">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[不得利用該舖位外面任何地方作儲存或陳列貨物之用，並不得在該等地方或其上面建有任何建築物或上蓋。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="311" width="17" height="15" uuid="d545fe1d-8c3b-4cb9-967d-9cc0fb871925">
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(25)]]></text>
			</staticText>
			<staticText>
				<reportElement x="65" y="353" width="464" height="30" uuid="d3349bf0-9821-4578-8ded-609860b35da8">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[不得在該舖位外任何部分張貼、促使或容許他人張貼海報、廣告或陳設招牌，但如經業主書面同意，並在
其認可之地點及按照其認可之方式進行者，則屬例外。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="353" width="17" height="15" uuid="60984376-78aa-4d8b-8bd2-6a11a40f1106">
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(26)]]></text>
			</staticText>
			<staticText>
				<reportElement x="65" y="394" width="464" height="80" uuid="d2cd251b-591b-4824-8fa7-c6bdc99cfaff">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[凡在該舖位內煮食或燒水，須使用電爐或其他電器用具或氣爐或其他使用石油氣為燃料之爐具(若使用以石
油氣為燃料之爐具，必須由業主認可之承辦商安裝)。但凡煮食或燒水，一律不得使用，或促使或容許他人
使用香港法例第311I章空氣污染管制(燃料限制)規例所指之傳統液體燃料或傳統固燃料。倘該舖位並非位
於香港法例第311I章空氣污染管制(燃料限制)規例所指之沙田燃料限制區內，則可使用其他以火水為燃料
之爐具。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="394" width="17" height="15" uuid="c795fc82-ae52-431d-bd0f-ee016ce35cdc">
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(27)]]></text>
			</staticText>
			<staticText>
				<reportElement x="65" y="476" width="464" height="15" uuid="be016fb8-be66-4eac-80fa-f2054594ab95">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[不得在該舖位任何部分豢養任何禽畜或牲口。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="476" width="17" height="15" uuid="91765b74-e0e5-4a73-94c9-fa67664ac447">
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(28)]]></text>
			</staticText>
			<staticText>
				<reportElement x="65" y="508" width="464" height="30" uuid="08c9ab37-480f-4ad6-88b4-b2d8168237b3">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[事先未經業主書面同意，不得將本租約所訂明承租人的權利和責任轉讓或出讓予任何第三方，又或以分租、特許、分享或其他方式將該舖位或其任何部分的管有權讓予任何第三方。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="508" width="17" height="15" uuid="e6738865-c910-43e8-aa2d-f935e1929755">
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(29)]]></text>
			</staticText>
			<staticText>
				<reportElement x="65" y="554" width="464" height="30" uuid="cd4d4f13-b124-46f9-af2b-4af1209d9936">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[准許業主包括其代理人及由其授權之人士在合理時間內均可進入巡視該舖位及點查其內之固定裝置及設
備，並進行業主份內之修理或其他工作。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="554" width="17" height="15" uuid="6f7a591f-0c7c-42c5-9681-48fc86ed0e0c">
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(30)]]></text>
			</staticText>
			<textField>
				<reportElement x="65" y="599" width="464" height="15" uuid="f3fd4229-569b-4737-8143-b6616564604a">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified" markup="html">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<textFieldExpression><![CDATA["由本租約開始生效之日起計<u>&emsp;&emsp;&emsp;&emsp;&emsp;&emsp;&emsp;&emsp;&emsp;&emsp;</u>個月內開始經營第II條(11)款所指定之行業。"]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="43" y="599" width="17" height="15" uuid="a1b00130-c31e-4420-a069-15d1c308e52c">
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(31)]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="24" width="17" height="15" uuid="3b2aa72c-46ed-477f-858d-789b92f2e772">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
					<property name="com.jaspersoft.studio.unit.x" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(20)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="24" width="465" height="30" uuid="580f7236-e55e-4679-9429-70c246ff0a2f">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
					<property name="com.jaspersoft.studio.unit.x" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[在該舖位內外，以及通至該舖位之通路上，不得進行、促使或容許他人進行妨礙、煩擾業主或鄰舍之事
情。
]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="66" width="17" height="15" uuid="565284d9-4bdf-40a8-a8cc-bcfafd22d1de">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.x" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(21)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="66" width="465" height="30" uuid="e9caebfe-5f7c-4a4c-bbc1-f7a7d3957095">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
					<property name="com.jaspersoft.studio.unit.x" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[晚上十一時至翌晨七時之間，不得促使或容許他人在該舖位內喧嘩吵鬧，造成騷擾，或發出令人煩厭的聲
響，以致妨礙他人安寧。]]></text>
			</staticText>
		</band>
		<band height="799">
			<staticText>
				<reportElement x="242" y="1" width="76" height="14" forecolor="#808080" uuid="be8bf1a4-ffbf-4a3b-9ca1-f49602bc1fec"/>
				<textElement textAlignment="Center"/>
				<text><![CDATA[4]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="251" width="465" height="87" uuid="77197d2b-abdb-4a01-8122-43f6d49b0dce">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[To open up all shutters during the opening hours of the said shop and to install and at all times maintain displays of merchandise goods or services in the shopfront windows or showcases contained within the entrance ways of the said shop to the satisfaction of the Landlord and to a standard and composition appropriate in the opinion of the Landlord to the reputation and standing of the *shopping centre/estate and to alter any window or other display of goods or merchandise in or at the said shop immediately upon notice by the Landlord that such display will in the opinion of the Landlord prejudice the reputation or standing of the *shopping centre/estate, provided always that
the opinion of the Landlord in the respect shall be final.]]></text>
			</staticText>
			<staticText>
				<reportElement x="42" y="251" width="17" height="15" uuid="15377f5e-5653-4dff-a35f-204b633e8c65">
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(35)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="339" width="465" height="47" uuid="af264154-fc72-4ad0-9eb2-a3a1c6d0313c">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[The Tenant shall be responsible for the maintenance, control and safety of the dumbwaiter or goods lift installed in the said shop and shall, for these purposes, employ a registered contractor to undertake regular maintenance to
keep the installation in good repair and to comply with the requirements of the Lifts and Escalator (Safety) Ordinance, Cap. 327, Code of Practice and Circular Letters of the Fire Services Department.]]></text>
			</staticText>
			<staticText>
				<reportElement x="42" y="339" width="17" height="15" uuid="c3905795-2a4a-4b73-b9d4-5925282c61db">
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(36)]]></text>
			</staticText>
			<staticText>
				<reportElement x="25" y="692" width="115" height="12" uuid="46dcd12d-f78c-44b6-a322-63581ec57197">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="8.5"/>
				</textElement>
				<text><![CDATA[* Delete if inapplicable ]]></text>
			</staticText>
			<staticText>
				<reportElement x="42" y="393" width="17" height="15" uuid="f50ec5a7-ab2a-488a-935e-7402453732ed">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(37)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="393" width="465" height="84" uuid="575e0747-22cf-4c68-bec9-4a238083331c">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[Not to add onto or allow to be added onto the said shop or any part thereof for any purpose whatsoever any
asbestos-containing material in any form whatsoever. If the Tenant is found to be in breach of this condition, the Tenant shall cause all such asbestos-containing material to be removed by a specialist asbestos remover to be approved by the Landlord to the satisfaction of the Landlord at the Tenant's sole cost and expense. In the event that the Tenant fails to remove such asbestos-containing material, the Landlord may do all things necessary to effect the removal of the same and any monies expended by the Landlord for the purpose shall be repayable by the Tenant on demand and be recoverable, by distress or otherwise, as for rent in arrears.]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="481" width="465" height="37" uuid="a0482cc0-ebc5-4b1b-bfd7-a13f2d5c3ffe">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[Not to overload the floors or ceilings of the said shop, or the structure of the said shop, or any plant, machinery, plumbing or electrical installation serving the said shop or the *shopping centre/estate nor to do anything which interferes with the heating, air-conditioning, plumbing or ventilation of the *shopping centre/estate.]]></text>
			</staticText>
			<staticText>
				<reportElement x="42" y="481" width="17" height="15" uuid="88e84484-bd38-43e0-bc4a-b239b99202c4">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(38)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="523" width="465" height="65" uuid="eb7b5624-413f-4038-a905-017610bb931e">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[To observe and comply with and perform all the covenants terms and provisions restrictions and prohibitions contained in the Deed of Mutual Covenant and Management Agreement (if any)(including but not limited to the building rules incorporated therein (if any)), the Sub Deed of Mutual Covenant (if any) and the Deed of Grant of Right of Way (if any) relating to the estate where the said shop is situate and shall indemnify the Landlord against the breach non-observance or non-performance thereof.]]></text>
			</staticText>
			<staticText>
				<reportElement x="42" y="523" width="17" height="15" uuid="c213b2af-d863-4672-a576-93e998d06bde">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(39)]]></text>
			</staticText>
			<staticText>
				<reportElement x="25" y="339" width="17" height="15" uuid="af43e01c-d405-45ae-b668-c172fc3763f2">
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Right">
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[*]]></text>
			</staticText>
			<staticText>
				<reportElement x="42" y="590" width="486" height="15" uuid="94e86abf-49d9-43f6-8fac-7213e3126367">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.x" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[The Landlord agrees with the Tenant as follows:—]]></text>
			</staticText>
			<staticText>
				<reportElement x="24" y="590" width="17" height="15" uuid="5fdf8dee-40b0-4e07-ab0d-43387fb233ca">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[III.]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="609" width="465" height="15" uuid="7c9d8eaa-078f-49ac-850b-ffd314498873">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[To keep the exterior of the said shop (except all glass and the shop front) in tenantable repair.]]></text>
			</staticText>
			<staticText>
				<reportElement x="42" y="609" width="17" height="15" uuid="3d8f8481-b131-4798-8916-e466f759591d">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(1)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="628" width="465" height="50" uuid="79492fbf-9fee-48f1-831a-8c776e96e3af">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[To keep the Landlord's fixtures and fittings and the drains pipes and sewers serving the said shop in tenantable
repair (where applicable at the cost of the Tenant as provided by Clause II (6) hereof); provided that the Landlord shall not be liable hereunder unless and until written notice of any want of repair shall have been served upon him and the Landlord shall have failed to take steps to effect the necessary repairs after the lapse of a reasonable time.]]></text>
			</staticText>
			<staticText>
				<reportElement x="42" y="628" width="17" height="15" uuid="cef0228f-4521-4d35-bc1a-3a0d6d41ea05">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(2)]]></text>
			</staticText>
			<staticText>
				<reportElement x="42" y="23" width="22" height="15" uuid="fae2337e-2ff3-4c91-a421-c17c715aec61">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(32)*]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="23" width="465" height="70" uuid="79610c57-fd6a-4438-8a39-f84941c5a934">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[To keep the said shop open for business not less than 20 days in any calendar month.  On each business day, the
said shop should open for a minimum of four hours.  The Tenant should obtain the prior consent from the
Landlord if he is not able to open the said shop for business for at least 20 days.  If the Tenant fails to observe or comply with this Clause II(32), it will be considered as a material breach of this agreement and the Landlord shall
be entitled to determine the tenancy under Clause IV(4) without prejudice to the rights of the Landlord under this agreement.]]></text>
			</staticText>
			<staticText>
				<reportElement x="42" y="98" width="22" height="15" uuid="097f0c8a-1e74-450b-bfe7-19864c98f07e">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Right">
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[*]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="98" width="465" height="70" uuid="93aeabc1-a5bd-41c5-bd2b-85ad77e8d8eb">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[To keep the said shop open for business between the hours of 10:00 a.m. and 8:00 p.m. (the “Core Business
Hours”) and the number of rest days will be limited to not more than 4 days in any calendar month except with
prior consent from the Landlord.  The Landlord has the absolute discretion to alter the Core Business Hours and
will notify the Tenant in a timely manner of the alteration.   If the Tenant fails to observe or comply with this
Clause II(32), it will be considered as a material breach of this agreement and the Landlord shall be entitled to determine the tenancy under Clause IV(4) without prejudice to the rights of the Landlord under this agreement.]]></text>
			</staticText>
			<staticText>
				<reportElement x="42" y="175" width="17" height="15" uuid="eaecb06c-8e87-4d00-9479-7e56e914adba">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(33)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="175" width="465" height="24" uuid="4df8e989-eac7-4cf5-bc59-bfb05022d601">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[To observe and comply with such rules and regulations not in conflict with the terms of this agreement, as may be made from time to time by the Landlord in respect of the use of the said shop by the Tenant.]]></text>
			</staticText>
			<staticText>
				<reportElement x="42" y="206" width="17" height="15" uuid="e933bcdf-be52-41f0-98a5-f8c8c5d75890">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(34)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="206" width="465" height="38" uuid="a0bc1758-b5b2-42ca-92d4-48220d45f192">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[On the expiration or determination of the tenancy hereby created or of any extension thereof forthwith to deliver
up vacant possession of the said shop to the Landlord together with all the Landlord's fixtures and fittings therein
in good and tenantable condition.]]></text>
			</staticText>
		</band>
		<band height="800">
			<staticText>
				<reportElement x="242" y="1" width="76" height="14" forecolor="#808080" uuid="97021ddb-aa75-4c76-a1d7-20ca43226c5d"/>
				<textElement textAlignment="Center"/>
				<text><![CDATA[第四頁]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="226" width="17" height="15" uuid="1d287c26-d4ef-42ad-99fe-5dd391733ec1">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(35)]]></text>
			</staticText>
			<staticText>
				<reportElement x="65" y="226" width="464" height="56" uuid="112a6834-2d46-4aa6-a92f-a1160e7f1bb6">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[在營業時間內，必須保持舖位閘門開啟及在舖面櫥窗或舖位入口處之飾櫃內安裝擺設，經常陳列店內所售
商品或展示該店所提供之服務；擺設方式必須令業主滿意，其水準及組合亦須符合業主意旨，務求配合*
商場/屋邨之聲譽及形象。若業主認為此等陳列有損*商場/屋邨之聲譽或形象，則承租人須在接獲業主通知
後，立即將櫥窗改裝，或更換該舖內所陳列之貨物或商品。在此方面，一切當以業主之意見為依歸。]]></text>
			</staticText>
			<staticText>
				<reportElement x="25" y="670" width="115" height="12" uuid="e5260e24-0cb7-4035-b7f7-024b05f6ab8b">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="新細明體" size="8"/>
				</textElement>
				<text><![CDATA[* 如不適用者刪去 ]]></text>
			</staticText>
			<staticText>
				<reportElement x="65" y="292" width="464" height="50" uuid="a66c1cdc-5962-49ff-8561-592e98b78409">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[有關安裝於該舖位內之傳菜或送貨升降機，承租人須負責予以維修、管理及確保其安全。為此，承租人必
須聘用一註冊承裝商負責定期維修該等升降機，確保修理妥善，以符合香港法例第三二七章升降機及電動
扶梯(安全)條例，以及消防處所發守則及通函之規定。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="292" width="17" height="15" uuid="bff58b4e-ae7b-4fec-8fe5-375f01044b07">
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(36)]]></text>
			</staticText>
			<staticText>
				<reportElement x="65" y="347" width="464" height="65" uuid="2d6e0443-38fb-41cd-aebe-54501186b58f">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[不得自行或容許他人以任何方式，在該舖位或其內部分加上任何含有石棉之物料作任何用途。承租人若違
反此項條款，一經發現，即須自費安排一名獲業主認可之專業石棉清拆商將所有石棉物料拆除，而清拆工
程亦須令業主滿意。倘若承租人未能拆除此等含有石棉之物料，則業主可採取一切必須行動將之拆除。業
主為此而支出之任何費用，得在其向承租人發出通知後，向承租人追討，或視作欠租，由業主以扣押財物
或其他方式索還。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="347" width="17" height="15" uuid="60d94b6d-7125-4618-8833-cbbef8b22500">
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(37)]]></text>
			</staticText>
			<staticText>
				<reportElement x="65" y="422" width="464" height="40" uuid="4afe8882-24ba-426c-8140-a2f61a42857e">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[不得使該舖位的樓板或天花、該舖位的結構、或為該舖位或該*商場／屋邨提供服務的任何機器、機械、水
管或電力裝置荷載過重，亦不得干擾該*商場／屋邨的暖氣、空調、水管或通風設施。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="422" width="17" height="15" uuid="3b08f842-5dcb-49c8-b8d0-3bab6449e29f">
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(38)]]></text>
			</staticText>
			<staticText>
				<reportElement x="65" y="466" width="464" height="46" uuid="1ebd5149-c6c7-4fc6-9f44-2d1b5ffdbe4b">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[遵守、遵從並履行與該商舖所在屋邨相關的公契及管理協議(如有者)(包括但不限於納入其內的大廈規則
(如有者))、公契分契(如有者)和通行權批約(如有者)上所載的一切契約、條款及條文、限制和禁制規
定，並就違反、不遵守或不履行此等規定的行為對業主作出彌償。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="466" width="17" height="15" uuid="c4cf3ffd-9f54-4ae2-a27e-6d02c63ceb04">
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(39)]]></text>
			</staticText>
			<staticText>
				<reportElement x="65" y="558" width="464" height="15" uuid="8e4933b6-eb98-4cf2-bec1-051187500796">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[負責將舖位之外部(玻璃及舖面除外)修理妥善，以供承租人使用。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="558" width="15" height="15" uuid="3427c23d-4fed-49ca-968c-d8707ba3ab7a">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(1)]]></text>
			</staticText>
			<staticText>
				<reportElement x="65" y="589" width="464" height="47" uuid="e2179fe9-79f1-4d5d-be24-8f19320d391e">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[負責將業主之固定裝置與設備、及該舖位之排水渠、水管及糞渠修理妥善，以供承租人使用(情況適用時，
得照本租約第II條(6)款之規定，由承租人負擔修理費用)。需要修理時，承租人必須以書面通知業主，
業主除非已接獲通知，而在一段合理時間後仍未採取步驟進行所需修理，否則不作失責論。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="589" width="15" height="15" uuid="d24383eb-66ef-4496-8671-b60828394d36">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(2)]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="527" width="476" height="15" uuid="a1cdfb8d-1024-461f-9aa9-2acaa47ecd65">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single"/>
				</textElement>
				<text><![CDATA[業主同意對承租人履行下開條款：]]></text>
			</staticText>
			<staticText>
				<reportElement x="25" y="527" width="17" height="15" uuid="68a4d913-8f69-4fab-99c5-bb920f9339a6">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[III.]]></text>
			</staticText>
			<staticText>
				<reportElement x="28" y="292" width="15" height="15" uuid="5e0422d1-6eed-49de-a245-faad4bd381f7">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
