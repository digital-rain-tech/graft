<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="NDMS-TN-0028" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" isTitleNewPage="true" uuid="d5d3b233-c781-4754-88c3-2ebe5a6e3c1b">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="NO_DATA_ADAPTER"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="400"/>
	<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="596"/>
	<import value="hk.gov.housingauthority.emms.ndms.framework.util.*"/>
	<parameter name="TNCY_AGRMT_KEY" class="java.lang.String"/>
	<parameter name="DOC_DATE" class="java.lang.String"/>
	<parameter name="DEPOSIT_AMT" class="java.lang.String"/>
	<parameter name="RATES_AMT" class="java.lang.String"/>
	<parameter name="AC_AMT" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT T2.*,
    fstEndDate_D - DOC_D + 1 NO_OF_DAYS,
	TO_CHAR(DOC_D, 'ddMMyyyy') DOC,
	TO_CHAR(SYSDATE, 'ddMMyyyy') CUR_DATE,
	TO_CHAR(fstEndDate_D, 'ddMMyyyy') fstEndDate,
	REPLACE(TO_CHAR(FIRST_RENT,'999,999,990.9'),'.0','') FIRST_RENT_TEXT,
	REPLACE(TO_CHAR(RENT_AMT,'999,999,990.9'),'.0','') RENT_TEXT,
	REPLACE(TO_CHAR(RATES_AMT,'999,999,990.9'),'.0','') RATES_TEXT,
	REPLACE(TO_CHAR(AC_AMT,'999,999,990.9'),'.0','') AC_TEXT,
	REPLACE(TO_CHAR(DEPOSIT_AMT,'999,999,990.9'),'.0','') DEPOSIT_TEXT,
	DECODE(FIRST_RENT,0,' ',
		CASE WHEN instr(FIRST_RENT,'.',1)=0
		THEN TO_CHAR(TO_DATE(FIRST_RENT,'J') ,'JSP')  || ' ONLY'
		WHEN instr(FIRST_RENT,'.',1)=1 AND FIRST_RENT<1
		THEN TO_CHAR(TO_DATE(MOD(FIRST_RENT*100,100),'J'), 'JSP') || ' CENTS ONLY' 
		ELSE 
		   TO_CHAR(TO_DATE(TRUNC(FIRST_RENT),'J'), 'JSP') || ' DOLLARS AND ' || 
		   TO_CHAR(TO_DATE(MOD(FIRST_RENT*100,100),'J'), 'JSP') || ' CENTS ONLY' 
		END)CURRENCY_FIRST_RENT_TEXT,
	DECODE(RENT_AMT,0,' ',
		CASE WHEN instr(RENT_AMT,'.',1)=0
		THEN TO_CHAR(TO_DATE(RENT_AMT,'J') ,'JSP')  || ' ONLY'
		WHEN instr(RENT_AMT,'.',1)=1 AND RENT_AMT<1
		THEN TO_CHAR(TO_DATE(MOD(RENT_AMT*100,100),'J'), 'JSP') || ' CENTS ONLY' 
		ELSE
		   TO_CHAR(TO_DATE(TRUNC(RENT_AMT),'J'), 'JSP') || ' DOLLARS AND ' || 
		   TO_CHAR(TO_DATE(MOD(RENT_AMT*100,100),'J'), 'JSP') || ' CENTS ONLY' 
		END)CURRENCY_RENT_TEXT,
	DECODE(RATES_AMT,0,' ',
		CASE WHEN instr(RATES_AMT,'.',1)=0
		THEN TO_CHAR(TO_DATE(RATES_AMT,'J') ,'JSP')  || ' ONLY'
		WHEN instr(RATES_AMT,'.',1)=1 AND RATES_AMT<1
		THEN TO_CHAR(TO_DATE(MOD(RATES_AMT*100,100),'J'), 'JSP') || ' CENTS ONLY' 
		ELSE 
		   TO_CHAR(TO_DATE(TRUNC(RATES_AMT),'J'), 'JSP') || ' DOLLARS AND ' || 
		   TO_CHAR(TO_DATE(MOD(RATES_AMT*100,100),'J'), 'JSP') || ' CENTS ONLY' 
		END )CURRENCY_RATES_TEXT,
	DECODE(DEPOSIT_AMT,0,' ',
		CASE WHEN instr(DEPOSIT_AMT,'.',1)=0
		THEN TO_CHAR(TO_DATE(DEPOSIT_AMT,'J') ,'JSP') || ' ONLY'
		WHEN instr(DEPOSIT_AMT,'.',1)=1 AND DEPOSIT_AMT<1
		THEN TO_CHAR(TO_DATE(MOD(DEPOSIT_AMT*100,100),'J'), 'JSP') || ' CENTS ONLY' 
		ELSE 
		   TO_CHAR(TO_DATE(TRUNC(DEPOSIT_AMT),'J'), 'JSP') || ' DOLLARS AND ' || 
		   TO_CHAR(TO_DATE(MOD(DEPOSIT_AMT*100,100),'J'), 'JSP') || ' CENTS ONLY' 
		END )CURRENCY_DEPOSIT_TEXT,
	REPLACE(TO_CHAR(NO_OF_RENTFREE*RENT_AMT, '999,999,990.9'),'.0','')  RENTFREE_AMT,
	TRIM(LEADING '0' FROM TO_CHAR(DOC_D,'Ddth', 'NLS_DATE_LANGUAGE=AMERICAN')) DOC_DAY,
	TO_CHAR(DOC_D,'Month YYYY', 'NLS_DATE_LANGUAGE=AMERICAN')DOC_MTHYEAR,
	TRIM(LEADING '0' FROM TO_CHAR(CURRENT_DATE,'Ddth', 'NLS_DATE_LANGUAGE=AMERICAN')) CUR_DATE_DAY,
	TO_CHAR(CURRENT_DATE,'Month YYYY', 'NLS_DATE_LANGUAGE=AMERICAN') CUR_DATE_MTHYEAR,
	TRIM(LEADING '0' FROM TO_CHAR(fstEndDate_D,'Ddth', 'NLS_DATE_LANGUAGE=AMERICAN')) fstEndDate_DAY,	
	TO_CHAR(fstEndDate_D,'Month YYYY', 'NLS_DATE_LANGUAGE=AMERICAN') fstEndDate_MTHYEAR
from(
SELECT T1.*,
  CASE WHEN TRUNC(DOC_D,'MM')=DOC_D
       THEN ROUND(RENT_AMT,1)
       ELSE ROUND(((LAST_DAY(DOC_D)- DOC_D+1)/TO_CHAR(LAST_DAY(DOC_D),'DD') * RENT_AMT+RENT_AMT),1)
  END FIRST_RENT,	
  CASE WHEN TRUNC(DOC_D,'MM')=DOC_D
       THEN ROUND(RATES,1)
       ELSE ROUND(((LAST_DAY(DOC_D)- DOC_D+1)/TO_CHAR(LAST_DAY(DOC_D),'DD') * RATES+RATES),1)
  END RATES_AMT
from(
	SELECT tam.TNCY_AGRMT_KEY,
	DECODE(customer.cust_type_code, 'P',customer.CUST_ENG_SRNM_NAME|| ' '  || customer.CUST_ENG_OTHR_NAME, customer.CMPY_ENG_NAME) as CUST_ENG_NAME,
	DECODE(customer.cust_type_code, 'P',customer.CUST_CHI_SRNM_NAME|| ' ' || customer.CUST_CHI_OTHR_NAME,customer.CMPY_CHI_NAME) as CUST_CHI_NAME,
	DECODE(customer.cust_type_code, 'P',substr(CUST_HKIC_NUM,1,length(CUST_HKIC_NUM)-1)||'('|| substr(CUST_HKIC_NUM,-1)||')',' ') as HKIC, 
	NVL(DECODE(customer.cust_type_code, 'C',NVL(CUST_BRC_NUM,CUST_CERT_INC_NUM),' '),' ') as BRN, 
	TRIM(stck.HSE_STCK_UNIT_CODE||stck.HSE_STCK_SPCL_CODE)||', '|| trim(STCK.HSE_STCK_PRMS_ENG_ADDR_2) SHOPNO_ENG,
	tam.TNCY_TOT_IFA_AREA IFA,
	trim(STCK.HSE_STCK_PRMS_ENG_ADDR_3)||', '||trim(STCK.HSE_STCK_PRMS_ENG_ADDR_4)||', '||trim(STCK.HSE_STCK_PRMS_ENG_ADDR_5) ENGADDR,
	trim(STCK.HSE_STCK_PRMS_CHI_ADDR_2)||trim(STCK.HSE_STCK_PRMS_CHI_ADDR_3)||trim(STCK.HSE_STCK_PRMS_CHI_ADDR_4)||trim(STCK.HSE_STCK_PRMS_CHI_ADDR_5) CHIADDR,
	to_date($P{DOC_DATE},'ddMMyyyy') DOC_D,
	CASE WHEN TRUNC(to_date($P{DOC_DATE},'ddMMyyyy'),'MM')=to_date($P{DOC_DATE},'ddMMyyyy')
	then LAST_DAY(to_date($P{DOC_DATE},'ddMMyyyy'))
	else LAST_DAY(ADD_MONTHS(to_date($P{DOC_DATE},'ddMMyyyy'),1))END fstEndDate_D,
	ROUND(NVL(rentlist.RENT_AMT,0),1) RENT_AMT,
	ROUND(NVL($P{RATES_AMT},0),1) RATES,
	ROUND(NVL($P{AC_AMT},0),1) AC_AMT,
	trd.TRD_CODE_ENG_DESP TRD_ENG,
	trd.TRD_CODE_CHI_DESP TRD_CHI,
	ROUND(NVL($P{DEPOSIT_AMT},0),1) DEPOSIT_AMT,
	(SELECT COUNT(TNCY_RENT_FREE_PRD_KEY) from  wrk_tncy_rent_free_prd rentFree where rentFree.TNCY_AGRMT_KEY=tam.TNCY_AGRMT_KEY and LAST_REC_TXN_TYPE_CODE!='D') NO_OF_RENTFREE
FROM HSM_HSE_STCK stck,
    WRK_TNCY_AGRMT tam , 
    SRF_TRD_CODE trd,
    CPM_CUST customer,
    WRK_TNCY_RENT_STRC rentstrc,
    (SELECT TNCY_RENT_STRC_KEY,TNCY_RENT_LIST_KEY,RENT_BGN_DATE,RENT_END_DATE,RENT_AMT,       
       ROW_NUMBER() OVER (PARTITION BY TNCY_RENT_STRC_KEY ORDER BY RENT_BGN_DATE,nvl(DOC_MTH_CNT,99)) AS idNum
      FROM WRK_TNCY_RENT_LIST
	  where LAST_REC_TXN_TYPE_CODE!='D') rentlist
WHERE  stck.HSE_STCK_KEY = tam.MAIN_STCK_KEY
AND trd.TRD_CODE=tam.TRD_CODE
AND tam.CUST_KEY = customer.CUST_KEY 
AND rentstrc.TNCY_AGRMT_KEY = tam.TNCY_AGRMT_KEY
AND rentlist.TNCY_RENT_STRC_KEY = rentstrc.TNCY_RENT_STRC_KEY
AND tam.TNCY_AGRMT_KEY = $P{TNCY_AGRMT_KEY}
AND tam.LAST_REC_TXN_TYPE_CODE != 'D'
AND stck.LAST_REC_TXN_TYPE_CODE!='D'
AND customer.LAST_REC_TXN_TYPE_CODE!='D'
AND trd.LAST_REC_TXN_TYPE_CODE != 'D'
AND rentstrc.LAST_REC_TXN_TYPE_CODE!='D'
AND rentlist.idNum=1) T1 ) T2]]>
	</queryString>
