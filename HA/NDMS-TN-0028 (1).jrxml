					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[. No mahjong]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="439" width="217" height="12" uuid="07cde9cd-86f2-44a5-bc8f-3c094244a243">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified" markup="html">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[playing by whoever is allowed in the said shop.]]></text>
			</staticText>
			<staticText>
				<reportElement x="28" y="19" width="15" height="15" uuid="d57c1761-1e23-4913-86fe-6c73f0a40504">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.x" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Right">
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[*]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="19" width="15" height="15" uuid="d6e5a9f7-226d-45e1-9a60-3e1b35808424">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.x" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[(3)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="19" width="342" height="12" uuid="cddaf301-1e9f-4a4f-ac09-93eeca7a2054">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified" markup="html">
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[To pay to the Landlord by way of additional rent, an air-conditioning charge of HK$]]></text>
			</staticText>
			<textField textAdjust="ScaleFont" isBlankWhenNull="true">
				<reportElement x="406" y="19" width="108" height="12" uuid="c2356aa4-69c7-4a6e-b46b-df996182c413">
					<property name="com.jaspersoft.studio.unit.x" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<box>
					<bottomPen lineWidth="1.0" lineStyle="Solid"/>
				</box>
				<textElement textAlignment="Center">
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{AC_AMT}==null || $F{AC_AMT}.compareTo(BigDecimal.ZERO) == 0 ? "" :  $F{AC_TEXT}]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement x="515" y="19" width="14" height="12" uuid="56a9aae7-b226-4623-aab6-ef966594b286">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.x" value="px"/>
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Right" markup="html">
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[per ]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="31" width="465" height="70" uuid="c0b22ebe-c4db-4ef4-850f-2d4ab1b34093">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified" markup="html">
					<font fontName="Times New Roman" size="10"/>
				</textElement>
				<text><![CDATA[month from the commencement of the term created herein or from the date upon which the air-conditioning is supplied to the said shop, whichever is the later date, the first payment to be made on a date specified by the Landlord and thereafter in advance on the first day of each month, provided always that if at any time during the said term the cost for the operation of the air-cooling services shall have risen, the Landlord shall be entitled to serve one month's notice in writing upon the Tenant increasing the charge for air-conditioning and thereafter such increased charge shall be payable in lieu of the charge provided for herein.]]></text>
			</staticText>
		</band>
		<band height="800">
			<staticText>
				<reportElement x="242" y="1" width="76" height="14" forecolor="#808080" uuid="c8fb0402-a4df-4a5b-9497-e3b5adc5c965"/>
				<textElement textAlignment="Center">
					<font size="10"/>
				</textElement>
				<text><![CDATA[第二頁]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="106" width="15" height="15" uuid="5fe1d1d7-0344-4b3a-bdf2-48bae567d05f">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(4)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="106" width="465" height="15" uuid="e91dbac8-3c10-44da-839e-1a5c3267b82a">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[繳交該舖位目前及日後所應繳之水費及電費。]]></text>
			</staticText>
			<staticText>
				<reportElement x="25" y="788" width="115" height="12" uuid="a3fbb829-b0e6-45f5-bb7a-c8e062ebeb63">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="新細明體" size="8"/>
				</textElement>
				<text><![CDATA[* 如不適用者刪去 ]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="135" width="465" height="30" uuid="442f820e-f0f7-47db-a73e-515162b21f33">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[在租賃期內，將該舖位之內部(包括內部裝飾及業主之固定裝置與設備)保持狀況良好及徹底整齊清潔(正常
損耗者除外)，並於業主認為需要時，依照出租時之顏色或業主認可之其他顏色，將該舖位之內部粉飾。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="135" width="15" height="15" uuid="fda70555-7469-46e8-8011-1f228dccb1d8">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(5)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="178" width="465" height="68" uuid="438cf86e-cced-42c9-bc89-d747d6e86aae">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[小心使用業主之固定裝置及設備，以及該舖位之糞渠、排水道等。上述任何一項物件損壞時(正常損耗者除
外)，業主得向承租人收取修理費用或更換費用。如承租人、其家人、僱員或其許可之人士因不慎而致糞渠
或排水道遭受淤塞，業主得向承租人收取疏導之費用。如承租人於事前未得業主同意而進行修理、更換或
疏導糞渠或排水道，事後業主未能滿意，而須再行修理、更換或疏導者，則承租人須負擔此類修理、更換
疏導之費用。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="178" width="15" height="15" uuid="3cb50a40-da26-48c6-bafc-e14d931131cc">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(6)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="258" width="465" height="15" uuid="8c901b1c-0222-4d03-8052-742168fa8ced">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[在租賃期內，若該舖位任何門窗之玻璃有破壞者，不論原因為何，均須自費將之更換。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="258" width="15" height="15" uuid="2d9e7c3c-567f-4e12-aebf-e3ba53bb08cf">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(7)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="287" width="465" height="15" uuid="83631bbf-8781-4b5e-8cca-e76b0b22f879">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[必須採取一切合理之預防措施，以確保該舖位內部不受暴風雨或颱風毀壞。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="287" width="15" height="15" uuid="bbb8841a-aa02-41cc-b5c5-db4b290e061f">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(8)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="316" width="465" height="30" uuid="86d0d03f-bc9b-44f2-a392-410054c50494">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[事前未經業主之書面同意，不得將該舖位或其內之任何電力或空氣調節設備作任何更改，亦不得在內安裝
任何固定裝置、間隔或其他架設，及不得將業主之固定裝置或設備移去。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="316" width="15" height="15" uuid="88ef51fc-7ce5-41fc-88a0-f5ce904609c9">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(9)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="359" width="465" height="30" uuid="6c32e5cc-555b-46ae-af99-9d4aa70321bb">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[倘該舖位任何部分因食水或渠水溢流，引致他人財產或身體遭受損害，並招致業主受控告或遭人索償時，
承租人須補償業主所蒙受之一切損失。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="359" width="17" height="15" uuid="4e312843-3517-47b9-9de0-b2d85439f07e">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(10)]]></text>
			</staticText>
			<staticText>
				<reportElement x="327" y="402" width="200" height="13" uuid="67591f1d-b956-48eb-bdc0-34975ee404b9">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Right" markup="html">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[外，不得在該舖位內外任何地方從事或容許他]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="402" width="17" height="15" uuid="f65772bf-4d0c-4547-8c39-c362b5e9d967">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(11)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="445" width="465" height="30" uuid="a0fba78c-87ac-45a5-b10a-35669c7fe481">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[不得在該舖位就任何種類的物品或財產進行或容許他人進行任何拍賣，惟與第II條(11)款所容許的行業、
職業、業務或活動有關並真正屬於季度或促銷特賣的物品或財產，則不在此限。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="445" width="17" height="15" uuid="542280c9-f292-485a-8b7d-a59493f816ed">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(12)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="488" width="465" height="30" uuid="b9e47cc6-a051-491b-9de9-0de69f2bd227">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[自費裝修舖面(包括招牌、飾櫃及門窗)，並在該舖位內配備傢具、各種固定裝置及設備，以符合業主及其
他機關之要求及達到其認為滿意之程度。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="488" width="17" height="15" uuid="4af37768-4f6c-496f-bd25-896b881ce6ae">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(13)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="531" width="465" height="30" uuid="06e8d7fd-1989-47fd-b703-bddfd8c5493a">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[必須自費為該舖位安裝招牌，並在店舖的營業時間和商場的公用地方向公眾開放的時間內，為招牌提供照
明，並須切實遵守這項規定。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="531" width="17" height="15" uuid="f85a1521-0e17-48b1-a1a3-a2caf3377101">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(14)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="574" width="465" height="30" uuid="4a907ef2-bc57-4a78-a486-dd7ef4fd0aae">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[在租賃期內，須經常遵守及履行一切法例、條例及規例，以及其他機關之一切附例、指示及法令之規定事
項；並須自費向有關當局領取經營該店舖業務所需之牌照及許可證。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="574" width="17" height="15" uuid="37f0c1e6-6d63-4583-9850-7a0d15d6e678">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement>
					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(15)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="617" width="465" height="30" uuid="4f7cd704-fa3b-4e27-8f25-597879ce338e">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[在租賃期內，若該舖位之業務是承租人獨資經營者，則不得接納股東加入；如其業務是合股經營者，則在
上述租期內不得接納新股東加入。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="617" width="17" height="15" uuid="70a34018-f432-4c85-be93-6685d4cec900">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
