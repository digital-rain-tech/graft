					<font fontName="Times New Roman" size="10"/>
					<paragraph lineSpacing="1_1_2"/>
				</textElement>
				<text><![CDATA[(18)]]></text>
			</staticText>
			<staticText>
				<reportElement x="64" y="732" width="465" height="45" uuid="66494e36-b12f-492f-92bd-20465019a091">
					<property name="com.jaspersoft.studio.unit.width" value="pixel"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.y" value="px"/>
				</reportElement>
				<textElement textAlignment="Justified">
					<font fontName="新細明體" size="10"/>
					<paragraph lineSpacing="Single" lineSpacingSize="1.0"/>
				</textElement>
				<text><![CDATA[未經業主事先給予書面許可，不得促使或容許承租人的任何傭工、僱員、獲其邀請的人、代理人、承辦商
或獲其特許的人在該舖位外面或該舖位所在的*商場／屋邨公用地方內的任何範圍招徠或兜攬生意，或派發
任何傳單、通告或廣告物品。]]></text>
			</staticText>
			<staticText>
				<reportElement x="43" y="732" width="17" height="15" uuid="fdf942cd-bd16-4752-8cd7-560d10c121b2">
