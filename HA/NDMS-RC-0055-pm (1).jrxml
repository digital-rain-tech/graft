							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement>
							<font fontName="SansSerif" size="7.5" isBold="true"/>
						</textElement>
						<textFieldExpression><![CDATA["7-Eleven/Circle K/VanGO Convenience Stores/ U select"]]></textFieldExpression>
					</textField>
					<textField textAdjust="StretchHeight">
						<reportElement x="21" y="11" width="239" height="10" uuid="cdda658c-ae37-4583-baf2-858194564048">
