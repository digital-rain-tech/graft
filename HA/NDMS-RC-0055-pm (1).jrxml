						<textElement>
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["租金/暫准證費及其他費用須在每個曆月之首日上期繳付。"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="31" width="14" height="11" uuid="21ce5b0e-5234-4e28-9ab9-2bcdb60c7c7f"/>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["2)"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="61" width="14" height="11" uuid="4c2e5f79-5d9a-42a6-a679-6ba6544816e4"/>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["3)"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="14" y="61" width="245" height="21" uuid="49490eb8-c9e5-4d6f-8144-b0b8b12a4077"/>
						<textElement verticalAlignment="Top">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["請按此月結單上的付款方法繳交款項，切勿把款項交給其他人士。"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="82" width="14" height="11" uuid="55794d18-4047-42c1-81e2-5e1a4b8a1daf"/>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["4)"]]></textFieldExpression>
					</textField>
					<staticText>
						<reportElement x="14" y="31" width="245" height="30" uuid="3ff2c5e8-958d-492b-abb4-87f90d78b904"/>
						<textElement>
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<text><![CDATA[不論業主有否正式催交,為免繳付租約/暫准證所訂的逾期利息，租
戶請於到期繳款日起計14天內清繳款項。]]></text>
					</staticText>
					<staticText>
						<reportElement x="14" y="82" width="245" height="28" uuid="5d775626-a5cd-41ad-b7cc-614d6dc1965c"/>
						<textElement>
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<text><![CDATA[如你已繳交此月結單內的到期租金，或對此月結單有任何查詢，請聯絡所屬屋邨辦事處或商場管理公司。]]></text>
					</staticText>
				</frame>
