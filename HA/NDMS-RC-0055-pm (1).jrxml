						<textElement markup="html">
							<font fontName="SansSerif" size="7.5"/>
							<paragraph lineSpacing="Proportional" lineSpacingSize="0.8"/>
						</textElement>
						<textFieldExpression><![CDATA["Use any mobile banking apps that supports Hong Kong Housing Authority QR code bill payment to scan the FPS QR code printed on this monthly statement to make payment."]]></textFieldExpression>
					</textField>
				</frame>
