						</textElement>
						<textFieldExpression><![CDATA["<P>Please pay in <b><u>cash</u></b> at any 7-Eleven.</P>"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="9" width="21" height="12" uuid="9a63757b-36fb-48c6-aeb5-0e9b379d21da">
