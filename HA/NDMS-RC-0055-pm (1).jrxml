						<textElement>
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["租金/暫准證費及其他費用須在每個曆月之首日上期繳付。"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="31" width="14" height="11" uuid="0ee621df-2bd9-407c-91dc-dbcbfdd5c266"/>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["2)"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="61" width="14" height="11" uuid="96b2db56-375a-444d-90af-77028c0ff51a"/>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["3)"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="14" y="61" width="245" height="21" uuid="3c28e884-b488-4af7-ba14-e03875038907"/>
						<textElement verticalAlignment="Top">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["請按此月結單上的付款方法繳交款項，切勿把款項交給其他人士。"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="82" width="14" height="11" uuid="c885fd6c-eef3-4510-b72d-16700fda548e"/>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["4)"]]></textFieldExpression>
