							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement verticalAlignment="Middle">
							<font fontName="SansSerif" size="7.5"/>
						</textElement>
						<textFieldExpression><![CDATA["4)"]]></textFieldExpression>
					</textField>
					<textField textAdjust="StretchHeight">
						<reportElement x="21" y="69" width="239" height="12" uuid="3ff4064c-01ef-4bf5-aeda-1a2db5b11a2a">
							<property name="com.jaspersoft.studio.unit.height" value="px"/>
							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement verticalAlignment="Middle">
							<font fontName="SansSerif" size="7.5"/>
						</textElement>
						<textFieldExpression><![CDATA["The number of daily payment per tenant code is up to 3."]]></textFieldExpression>
					</textField>
					<staticText>
						<reportElement x="21" y="10" width="239" height="21" uuid="e53c9c8e-06b3-43ec-b059-9087859fa4c3"/>
						<textElement>
							<font fontName="SansSerif" size="7.5"/>
							<paragraph lineSpacing="Proportional" lineSpacingSize="0.9"/>
						</textElement>
						<text><![CDATA[By phone : Please call 18031, then enter Merchant Code 62, and
follow the instructions for payment.]]></text>
					</staticText>
					<staticText>
						<reportElement x="21" y="41" width="239" height="30" uuid="cdb40f76-a5e0-43b1-9346-f405b922af42">
							<property name="com.jaspersoft.studio.unit.height" value="px"/>
						</reportElement>
						<textElement>
							<font fontName="SansSerif" size="7.5"/>
							<paragraph lineSpacing="Proportional" lineSpacingSize="0.9"/>
						</textElement>
						<text><![CDATA[The payment cut-off time is 7 p.m. (Monday to Friday). Payments
made after 7 p.m. will be recorded as payment made on the next
business day.]]></text>
					</staticText>
				</frame>
				<frame>
					<reportElement x="0" y="458" width="260" height="82" uuid="54ba5df2-dd2d-449d-ac94-3aa167384e52">
						<property name="com.jaspersoft.studio.unit.height" value="px"/>
						<property name="com.jaspersoft.studio.unit.y" value="px"/>
					</reportElement>
					<textField textAdjust="StretchHeight">
						<reportElement x="0" y="1" width="260" height="10" uuid="2771df19-b7c2-432f-b931-adaa43873eb2">
							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement verticalAlignment="Middle">
							<font fontName="SansSerif" size="7.5" isBold="true"/>
						</textElement>
						<textFieldExpression><![CDATA["Automatic Teller Machine (ATM)"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="10" width="21" height="12" uuid="e1e00cd0-9f1d-4f93-ae79-78daa2b8e363"/>
