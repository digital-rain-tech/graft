							<paragraph lineSpacing="Proportional" lineSpacingSize="0.8"/>
						</textElement>
						<textFieldExpression><![CDATA["<P>Please pay in <b><u>cash</u></b> at any 7-Eleven.</P>"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="9" width="21" height="12" uuid="de3d8bce-9ce1-4611-af0c-2d1da9f352c7">
