					</textElement>
					<textFieldExpression><![CDATA["Payment Methods "]]></textFieldExpression>
				</textField>
				<frame>
					<reportElement x="0" y="10" width="260" height="61" uuid="1085afb6-8f0a-4e42-a86e-3f81d645a937">
