							<property name="com.jaspersoft.studio.unit.height" value="px"/>
							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement>
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<text><![CDATA[劃線支票抬頭寫上「香港房屋委員會」，並於支票背頁寫上電子繳費
租戶號碼。]]></text>
					</staticText>
					<textField>
						<reportElement x="0" y="65" width="14" height="11" uuid="70f1ac21-22d6-4b11-ba35-355f46159122"/>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["●"]]></textFieldExpression>
					</textField>
					<staticText>
						<reportElement x="0" y="52" width="258" height="15" uuid="86e8c842-5390-475d-a021-314313bb8849">
							<property name="com.jaspersoft.studio.unit.height" value="px"/>
						</reportElement>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8" isBold="true"/>
						</textElement>
						<text><![CDATA[OK便利店/VanGO便利店/U購select (只接受現金或EPS)]]></text>
					</staticText>
					<staticText>
						<reportElement x="0" y="40" width="258" height="15" uuid="e047a04e-b2e7-480c-9018-7af2bf74efbf">
							<property name="com.jaspersoft.studio.unit.height" value="px"/>
						</reportElement>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8" isBold="true"/>
						</textElement>
						<text><![CDATA[7-Eleven(只接受現金)]]></text>
					</staticText>
					<staticText>
						<reportElement x="14" y="66" width="245" height="42" uuid="a641f855-7fac-4af2-99fe-f9f29db89665">
							<property name="com.jaspersoft.studio.unit.height" value="px"/>
						</reportElement>
						<textElement>
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<text><![CDATA[繳款時，請出示月結單。租戶繳款後請小心核對並確保收據上的資料
無誤。並請保留收據（或按需要複印）及月結單，作為繳付紀錄，以
便核對。]]></text>
					</staticText>
				</frame>
				<frame>
					<reportElement x="0" y="376" width="259" height="87" uuid="e020e6c5-da15-4e2c-b683-7b3e7e6efcd9">
						<property name="com.jaspersoft.studio.unit.y" value="px"/>
					</reportElement>
					<textField>
						<reportElement x="0" y="0" width="238" height="12" uuid="3f0650f6-5c03-4fe1-aff1-15549610b375"/>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8.5" isBold="true"/>
						</textElement>
						<textFieldExpression><![CDATA["繳費靈"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="10" width="14" height="11" uuid="93d57356-bb66-4484-8afb-589780f1af5d"/>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["1)"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="31" width="14" height="11" uuid="71aff275-6f3e-49dc-a777-5db0a1a881f8"/>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["2)"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="14" y="31" width="245" height="11" uuid="b661d26c-1a52-4b82-ad45-0693126d84fc"/>
						<textElement verticalAlignment="Middle" markup="html">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["以「繳費靈網上服務」繳付：網址為 <u>www.ppshk.com</u>。"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="41" width="14" height="11" uuid="47d4175c-6764-4010-97d6-63158927ad38"/>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["3)"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="71" width="14" height="11" uuid="0479805b-32d6-458d-9093-bdb1d7bb2aaf">
							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["4)"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="14" y="71" width="245" height="11" uuid="662f943d-55d1-4116-963e-61d75bc4d9e2">
							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["每個租戶號碼，一天內最多只能繳交3次。"]]></textFieldExpression>
					</textField>
					<staticText>
						<reportElement x="14" y="10" width="245" height="22" uuid="2ace6a3d-16a3-4557-875f-e40a80a71e6e"/>
						<textElement>
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<text><![CDATA[以電話繳付 : 請撥18033，然後輸入商戶編號62，再遵照電話錄音提
示繳付。]]></text>
					</staticText>
					<staticText>
						<reportElement x="14" y="41" width="245" height="30" uuid="9ca2933c-186c-4314-af0e-f27d8024ade6">
							<property name="com.jaspersoft.studio.unit.height" value="px"/>
						</reportElement>
						<textElement verticalAlignment="Top">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<text><![CDATA[繳款截數時間為每日下午7時正(星期一至五)。租戶於下午7時後所交
款項，將紀錄為下一個工作天的收款。]]></text>
					</staticText>
				</frame>
				<frame>
					<reportElement x="0" y="462" width="259" height="83" uuid="f09d73d5-e28e-47c8-81c3-ab70beb23c04">
						<property name="com.jaspersoft.studio.unit.y" value="px"/>
					</reportElement>
					<textField>
						<reportElement x="0" y="0" width="259" height="12" uuid="2a2b5647-95e8-41dd-ac06-0ec897b6b666"/>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8.5" isBold="true"/>
						</textElement>
						<textFieldExpression><![CDATA["自動櫃員機"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="10" width="14" height="11" uuid="4fef664b-a196-4dc0-887c-8b3a22515e52"/>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["1)"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="48" width="14" height="11" uuid="a3de6fa6-e67d-4a5b-b108-ebf2d957ba78">
							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["2)"]]></textFieldExpression>
					</textField>
					<staticText>
						<reportElement x="14" y="10" width="245" height="38" uuid="5096eac3-6407-429f-a242-eab0cedb9a93">
							<property name="com.jaspersoft.studio.unit.height" value="px"/>
						</reportElement>
						<textElement>
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<text><![CDATA[請以滙豐或恒生銀行發出的提款卡或具備提款功能的信用卡在滙豐或
恒生銀行的自動櫃員機繳付。請保留通知書，以便核對。]]></text>
					</staticText>
					<staticText>
						<reportElement x="14" y="48" width="245" height="33" uuid="0b6b2d4a-a288-4b5b-ae0b-fc584c7d8601">
							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement>
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<text><![CDATA[繳款截數時間為每日下午7時30分正(星期一至五)。租戶於下午7時30
分後所交款項，將紀錄為下一個工作天的收款。]]></text>
					</staticText>
				</frame>
				<frame>
					<reportElement x="0" y="544" width="259" height="70" uuid="aa6dd370-9e4e-4f02-8437-c076f05c1fa3">
						<property name="com.jaspersoft.studio.unit.y" value="px"/>
						<property name="com.jaspersoft.studio.unit.height" value="px"/>
					</reportElement>
					<textField>
						<reportElement x="0" y="0" width="259" height="12" uuid="5ef79d44-6d48-4eda-b768-728efe608320"/>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8.5" isBold="true"/>
						</textElement>
						<textFieldExpression><![CDATA["網上 / 電話理財"]]></textFieldExpression>
					</textField>
					<staticText>
						<reportElement x="0" y="10" width="259" height="60" uuid="92da355c-0012-4c5a-83f7-4b5302a48d47">
							<property name="com.jaspersoft.studio.unit.height" value="px"/>
						</reportElement>
						<textElement>
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<text><![CDATA[持有銀行「網上理財」或「電話理財」戶口的租戶，可以透過互聯網和
音頻電話繳交租金。你應按個別銀行系統的指示，選擇「香港房屋委員
會」作為收款商戶，並輸入你的電子繳費租戶號碼；請保留交易編號以
作記錄。請留意個別銀行的截數時間。]]></text>
					</staticText>
				</frame>
				<frame>
					<reportElement x="0" y="613" width="259" height="32" uuid="501ba5c9-8a4f-4504-a647-036fc49df410">
						<property name="com.jaspersoft.studio.unit.y" value="px"/>
					</reportElement>
					<textField>
						<reportElement x="0" y="-1" width="259" height="12" uuid="e5b1738d-a984-4de8-ab46-36e335387318"/>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8.5" isBold="true" isUnderline="true"/>
						</textElement>
						<textFieldExpression><![CDATA["支票退回/自動轉帳被拒"]]></textFieldExpression>
					</textField>
					<staticText>
						<reportElement x="0" y="9" width="259" height="22" uuid="97c40ef3-e5d3-48c3-884e-d55cf2b87705"/>
						<textElement>
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<text><![CDATA[若閣下用以繳付租金之支票或所指定之自動轉帳因退回而未能成功繳付
租金，則有可能被徵收逾期利息。]]></text>
					</staticText>
				</frame>
				<frame>
					<reportElement x="0" y="645" width="259" height="110" uuid="e31d8249-3303-4314-ae77-124e1447bce8">
						<property name="com.jaspersoft.studio.unit.y" value="px"/>
					</reportElement>
					<textField>
						<reportElement x="0" y="0" width="259" height="12" uuid="24163459-71bc-45eb-ac25-df1aab846df1"/>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8.5" isBold="true" isUnderline="true"/>
						</textElement>
						<textFieldExpression><![CDATA["備註："]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="10" width="14" height="11" uuid="14762af2-6472-414c-9f42-f68b3b70c3d9"/>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["1)"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="14" y="10" width="245" height="21" uuid="becd9705-15e7-4c38-9fbc-9f4639846414"/>
						<textElement>
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["租金/暫准證費及其他費用須在每個曆月之首日上期繳付。"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="31" width="14" height="11" uuid="cdc6b6a2-d1c7-4e76-9fe2-760069d86a93"/>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["2)"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="61" width="14" height="11" uuid="b22afbc5-323c-4430-a339-8780d20cb8ac"/>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["3)"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="14" y="61" width="245" height="21" uuid="519ce0e2-fec6-47a0-9088-74b119430cdf"/>
						<textElement verticalAlignment="Top">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["請按此月結單上的付款方法繳交款項，切勿把款項交給其他人士。"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="82" width="14" height="11" uuid="592f1539-cb9c-4b32-9684-1a64a3028134"/>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["4)"]]></textFieldExpression>
					</textField>
					<staticText>
						<reportElement x="14" y="31" width="245" height="30" uuid="c93f5856-e6ad-40d4-8ec2-8f36d3e56874"/>
						<textElement>
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<text><![CDATA[不論業主有否正式催交，為免繳付租約/暫准證所訂的逾期利息，租
戶請於到期繳款日起計14天內清繳款項。]]></text>
					</staticText>
					<staticText>
						<reportElement x="14" y="82" width="245" height="28" uuid="492de1a1-c86d-4c50-8dca-8359c73b5aae"/>
						<textElement>
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<text><![CDATA[如你已繳交此月結單內的到期租金，或對此月結單有任何查詢，請聯絡所屬屋邨辦事處或商場管理公司。]]></text>
					</staticText>
				</frame>
				<frame>
					<reportElement x="0" y="765" width="259" height="31" uuid="03a623cb-055e-45be-b725-ef0772877003">
						<property name="com.jaspersoft.studio.unit.y" value="px"/>
					</reportElement>
					<textField>
						<reportElement x="0" y="0" width="259" height="12" uuid="f856e67d-de26-40e0-b541-dc924406211e"/>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8.5" isBold="true" isUnderline="true"/>
						</textElement>
						<textFieldExpression><![CDATA["更改通訊地址"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="10" width="259" height="21" uuid="dae7be9d-d7dc-4b35-8bd2-a941b02d169c"/>
						<textElement>
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["通訊地址如有更改，請通知屋邨辦事處或商場管理公司職員。"]]></textFieldExpression>
					</textField>
				</frame>
			</frame>
