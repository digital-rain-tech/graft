					<textField textAdjust="StretchHeight">
						<reportElement x="21" y="21" width="239" height="12" uuid="6b1c4adf-ca53-4220-94a5-5d10a7768039">
							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement markup="html">
							<font fontName="SansSerif" size="7.5"/>
							<paragraph lineSpacing="Proportional" lineSpacingSize="0.8"/>
						</textElement>
						<textFieldExpression><![CDATA["<P>Please pay in <b><u>cash</u></b> or <b><u>EPS</u></b> at any Circle K, VanGO<br>Convenience Stores or U select.</P>"]]></textFieldExpression>
					</textField>
					<staticText>
						<reportElement x="21" y="38" width="239" height="67" uuid="654807fd-d743-42be-b1ee-d79b5f374451">
							<property name="com.jaspersoft.studio.unit.height" value="px"/>
							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement>
							<font fontName="SansSerif" size="7.5"/>
							<paragraph lineSpacing="Proportional" lineSpacingSize="0.9"/>
						</textElement>
						<text><![CDATA[The payment cut-off time is 5 p.m. everyday. Payments made
after 5 p.m. will be recorded as payment made on the next
business day. Their hotlines are as follows:
7-Eleven Convenience Stores: 2299 1110.
Circle K Convenience Stores: 2991 6337.
VanGO Convenience Stores : 2586 3567.
U select : 2586 3686.]]></text>
					</staticText>
				</frame>
