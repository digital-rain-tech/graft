							<font fontName="SansSerif" size="7.5" isBold="true" isUnderline="true"/>
						</textElement>
						<textFieldExpression><![CDATA["Change of Correspondence Address"]]></textFieldExpression>
					</textField>
					<staticText>
						<reportElement x="0" y="10" width="260" height="21" uuid="259f78b8-28fd-425d-94e4-918508b4cd1a"/>
						<textElement>
							<font fontName="SansSerif" size="7.5"/>
							<paragraph lineSpacing="Proportional" lineSpacingSize="0.8"/>
						</textElement>
						<text><![CDATA[Please notify staff of the estate office or property management
companies for any change of your correspondence address.]]></text>
					</staticText>
				</frame>
			</frame>
		</band>
	</detail>
</jasperReport>
