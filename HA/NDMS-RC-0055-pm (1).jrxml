							<font fontName="Arial Unicode MS" size="8.5" isBold="true" isUnderline="true"/>
						</textElement>
						<textFieldExpression><![CDATA["更改通訊地址"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="10" width="259" height="21" uuid="ff61116b-7b8d-4011-95d0-85048e3f1aec"/>
						<textElement>
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["通訊地址如有更改，請通知屋邨辦事處或商場管理公司職員。"]]></textFieldExpression>
					</textField>
				</frame>
			</frame>
			<frame>
