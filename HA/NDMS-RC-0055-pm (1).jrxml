							<font fontName="Arial Unicode MS" size="8.5" isBold="true"/>
						</textElement>
						<textFieldExpression><![CDATA["屋邨繳費處"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="10" width="259" height="20" uuid="9df5e392-7292-4179-9391-b06ff2c551dc"/>
						<textElement markup="html">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["可於任何屋邨繳費處的服務時間內以<b><u>現金或劃線支票</u></b>繳付。"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="30" width="259" height="12" uuid="c7222d92-c10b-447e-9a80-3524d1db55a1"/>
						<textElement>
							<font fontName="Arial Unicode MS" size="8.5" isBold="true"/>
						</textElement>
						<textFieldExpression><![CDATA["注意事項"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="107" width="259" height="12" uuid="b6be11f6-5f05-40be-af17-0cdc7bab4bf7">
							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement markup="none">
							<font fontName="Arial Unicode MS" size="8.5" isBold="true"/>
						</textElement>
						<textFieldExpression><![CDATA["屋邨繳費處 (可接受現金或劃線支票)"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="14" y="117" width="245" height="11" uuid="0eaa0a25-108b-4b1e-a62e-76ab0d559d29">
							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement>
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["期票／現金支票恕不接受。"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="117" width="14" height="11" uuid="b296d1dc-c03c-4e5b-9599-484b4a12ea69">
