						<textElement>
							<font fontName="Arial Unicode MS" size="8.5" isBold="true"/>
						</textElement>
						<textFieldExpression><![CDATA["7-Eleven/OK便利店/VanGO便利店/U購select"]]></textFieldExpression>
					</textField>
					<staticText>
						<reportElement x="14" y="40" width="245" height="67" uuid="e454e9f8-5bf6-470b-a1d1-7710286d6075">
							<property name="com.jaspersoft.studio.unit.height" value="px"/>
