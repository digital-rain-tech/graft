						</reportElement>
						<textElement>
							<font fontName="SansSerif" size="7.5"/>
							<paragraph lineSpacing="Proportional" lineSpacingSize="0.9"/>
						</textElement>
						<text><![CDATA[The payment cut-off time is 7:30 p.m. (Monday to Friday).
Payments made after 7:30 p.m. will be recorded as payment made
on the next business day.]]></text>
					</staticText>
				</frame>
				<frame>
					<reportElement x="0" y="540" width="260" height="70" uuid="c8d8cad3-3374-4890-a36d-56ec48f65a0c">
