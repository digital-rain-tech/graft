						</textElement>
						<textFieldExpression><![CDATA["屋邨繳費處 (可接受現金或劃線支票)"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="14" y="117" width="245" height="11" uuid="a1ba635a-f34a-4ea3-91e4-61891615e886">
