<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="NDMS-RC-0055-pm" pageWidth="595" pageHeight="842" whenNoDataType="NoPages" columnWidth="519" leftMargin="38" rightMargin="38" topMargin="10" bottomMargin="28" uuid="5187db77-e0a9-4778-a45a-f8c23a9ffaa2">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="NDMS_UAT"/>
