						</textElement>
						<textFieldExpression><![CDATA["轉數快"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="10" width="259" height="25" uuid="61bd62a4-4d46-42e0-b66a-660c5bfd2bba">
