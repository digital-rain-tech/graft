						<textElement>
							<font fontName="SansSerif" size="7.5"/>
							<paragraph lineSpacing="Proportional" lineSpacingSize="0.8"/>
						</textElement>
						<text><![CDATA[Please make a crossed cheque payable to ‘Hong Kong Housing
Authority’, and write down your Electronic Payment Tenant Code
on the back of your cheque.]]></text>
					</staticText>
