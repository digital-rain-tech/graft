					<textField>
						<reportElement x="0" y="48" width="21" height="12" uuid="4c800527-bcc2-43ef-ae84-fef4a00bbf1a">
							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement verticalAlignment="Middle">
							<font fontName="SansSerif" size="7.5"/>
						</textElement>
						<textFieldExpression><![CDATA["2)"]]></textFieldExpression>
					</textField>
					<staticText>
						<reportElement x="21" y="10" width="239" height="38" uuid="8de6203c-1155-471f-b173-a8b8b9692ed5">
							<property name="com.jaspersoft.studio.unit.height" value="px"/>
						</reportElement>
						<textElement>
							<font fontName="SansSerif" size="7.5"/>
							<paragraph lineSpacing="Proportional" lineSpacingSize="0.9"/>
						</textElement>
						<text><![CDATA[Simply use any ATM cards or credit cards with the ATM function
issued by HSBC or Hang Seng Bank Ltd (HSB) to make your
payment at any ATM of HSBC / HSB. Please retain the customer
advice for checking.]]></text>
					</staticText>
					<staticText>
						<reportElement x="21" y="48" width="239" height="34" uuid="d550e3ec-3237-45a9-84a9-9c2cc15e9b74">
							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement>
							<font fontName="SansSerif" size="7.5"/>
							<paragraph lineSpacing="Proportional" lineSpacingSize="0.9"/>
						</textElement>
						<text><![CDATA[The payment cut-off time is 7:30 p.m. (Monday to Friday).
Payments made after 7:30 p.m. will be recorded as payment made
on the next business day.]]></text>
					</staticText>
				</frame>
				<frame>
					<reportElement x="0" y="540" width="260" height="70" uuid="1c6f7187-78e9-4208-adca-bb8c3c771a9b">
						<property name="com.jaspersoft.studio.unit.y" value="px"/>
						<property name="com.jaspersoft.studio.unit.height" value="px"/>
					</reportElement>
					<textField textAdjust="StretchHeight">
						<reportElement x="0" y="0" width="260" height="10" uuid="c36bbc85-1b3b-47ea-b4be-fbcac586b83c">
							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement verticalAlignment="Middle">
							<font fontName="SansSerif" size="7.5" isBold="true"/>
						</textElement>
						<textFieldExpression><![CDATA["Internet / Phone Banking Service"]]></textFieldExpression>
					</textField>
					<staticText>
						<reportElement x="0" y="7" width="260" height="63" uuid="4b87ae27-2ab5-43d7-9016-7972dc88660f">
							<property name="com.jaspersoft.studio.unit.height" value="px"/>
							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement>
							<font fontName="SansSerif" size="7.5"/>
							<paragraph lineSpacing="Proportional" lineSpacingSize="0.8"/>
						</textElement>
						<text><![CDATA[Internet banking or phone banking account holders can pay rent through
the internet and any tone phone. You should follow the instructions of the
respective systems. Remember to choose “Hong Kong Housing
Authority” as the merchant, and enter your Electronic Payment Tenant
Code which is printed on your monthly statement to effect payment. You
are advised to keep the transaction reference code for record. Please
pay attention to the cut-off time of Respective Bank.]]></text>
					</staticText>
				</frame>
				<frame>
					<reportElement x="0" y="613" width="260" height="32" uuid="3a8d3ba4-4806-4897-bd04-9d1f0db5a440">
						<property name="com.jaspersoft.studio.unit.y" value="px"/>
					</reportElement>
					<textField textAdjust="StretchHeight">
						<reportElement x="0" y="1" width="260" height="10" uuid="a44629a8-21ff-4b19-b1b5-6bce6fb9aa62">
							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement verticalAlignment="Middle">
							<font fontName="SansSerif" size="7.5" isBold="true" isUnderline="true"/>
						</textElement>
						<textFieldExpression><![CDATA["Rejected Payment by Returned Cheques/Delinquent Autopay"]]></textFieldExpression>
					</textField>
					<staticText>
						<reportElement x="0" y="10" width="260" height="21" uuid="957ae9f0-c8a3-49d1-bc82-81829900545f"/>
						<textElement>
							<font fontName="SansSerif" size="7.5"/>
							<paragraph lineSpacing="Proportional" lineSpacingSize="0.9"/>
						</textElement>
						<text><![CDATA[Interest may be levied when a cheque payment or a direct debit payment
is returned unpaid.]]></text>
					</staticText>
				</frame>
				<frame>
					<reportElement x="0" y="645" width="260" height="120" uuid="3c1046e0-1b5d-4005-9073-1770724ca2aa">
