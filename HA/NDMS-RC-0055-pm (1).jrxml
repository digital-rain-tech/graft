							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement verticalAlignment="Middle">
							<font fontName="SansSerif" size="7.5" isBold="true"/>
						</textElement>
						<textFieldExpression><![CDATA["Internet / Phone Banking Service"]]></textFieldExpression>
					</textField>
					<staticText>
						<reportElement x="0" y="7" width="260" height="63" uuid="837497a3-d4fa-43eb-835c-9f3a0f6d040b">
							<property name="com.jaspersoft.studio.unit.height" value="px"/>
							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement>
							<font fontName="SansSerif" size="7.5"/>
							<paragraph lineSpacing="Proportional" lineSpacingSize="0.8"/>
						</textElement>
						<text><![CDATA[Internet banking or phone banking account holders can pay rent through
the internet and any tone phone. You should follow the instructions of the
respective systems. Remember to choose “Hong Kong Housing
Authority” as the merchant, and enter your Electronic Payment Tenant
Code which is printed on your monthly statement to effect payment. You
are advised to keep the transaction reference code for record. Please
pay attention to the cut-off time of Respective Bank.]]></text>
					</staticText>
				</frame>
				<frame>
					<reportElement x="0" y="613" width="260" height="32" uuid="65e8e320-4bef-4e85-8b1c-43a5f3b6c2fc">
