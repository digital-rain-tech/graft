							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement verticalAlignment="Middle">
							<font fontName="SansSerif" size="7.5" isBold="true" isUnderline="true"/>
						</textElement>
						<textFieldExpression><![CDATA["Rejected Payment by Returned Cheques/Delinquent Autopay"]]></textFieldExpression>
					</textField>
					<staticText>
						<reportElement x="0" y="10" width="260" height="21" uuid="774c599f-f79c-4e5f-a530-4b4b58d8a3a4"/>
						<textElement>
							<font fontName="SansSerif" size="7.5"/>
							<paragraph lineSpacing="Proportional" lineSpacingSize="0.9"/>
						</textElement>
						<text><![CDATA[Interest may be levied when a cheque payment or a direct debit payment
is returned unpaid.]]></text>
					</staticText>
				</frame>
