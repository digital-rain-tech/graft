							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["<P>可於7-Eleven以<b><u>現金</u></b>繳付。</P>"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="14" y="24" width="245" height="14" uuid="208c0c9a-fbaf-4437-b44c-360a4c81b30f">
							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement markup="html">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["<P>可於OK便利店、VanGO便利店或U購select以<b><u>現金</u></b>或<b><u>EPS</u></b>繳付。</P>"]]></textFieldExpression>
					</textField>
					<staticText>
						<reportElement x="14" y="40" width="245" height="67" uuid="aa2c3b73-6dca-4425-869f-831c893197ad">
							<property name="com.jaspersoft.studio.unit.height" value="px"/>
							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement>
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<text><![CDATA[繳款截數時間為每日下午5時正。租戶於下午5時後所交款項，將紀錄
為下一個工作天的收款。便利店/超級巿場熱線電話如下:
7-Eleven便利店 : 2299 1110。
OK便利店 : 2991 6337。
VanGO便利店 : 2586 3567。
U購select : 2586 3686。]]></text>
					</staticText>
				</frame>
