							<font fontName="Arial Unicode MS" size="8.5" isBold="true" isUnderline="true"/>
						</textElement>
						<textFieldExpression><![CDATA["備註："]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="10" width="14" height="11" uuid="0a746337-7f50-48fc-89cb-c5168908b486"/>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["1)"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="14" y="10" width="245" height="21" uuid="b05e0680-0f65-490c-abe1-0cf9dfb24286"/>
						<textElement>
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["租金/暫准證費及其他費用須在每個曆月之首日上期繳付。"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="31" width="14" height="11" uuid="b3c4173e-cff4-4b6b-994a-13e28b19c47c"/>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["2)"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="61" width="14" height="11" uuid="731a5c4f-ffcd-4051-abea-789270802de1"/>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["3)"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="14" y="61" width="245" height="21" uuid="900fe8e8-3618-4e6a-9a68-cd6cf6102230"/>
						<textElement verticalAlignment="Top">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["請按此月結單上的付款方法繳交款項，切勿把款項交給其他人士。"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="82" width="14" height="11" uuid="670bf086-82ec-4c87-a875-a8bf2fb70709"/>
						<textElement verticalAlignment="Middle">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["4)"]]></textFieldExpression>
