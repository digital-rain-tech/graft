						<reportElement x="0" y="10" width="259" height="20" uuid="8a6cd224-9575-4c66-8bcb-195af460e973"/>
						<textElement markup="html">
							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["可於任何屋邨繳費處的服務時間內以<b><u>現金或劃線支票</u></b>繳付。"]]></textFieldExpression>
					</textField>
