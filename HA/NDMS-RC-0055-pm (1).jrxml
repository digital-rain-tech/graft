						<textFieldExpression><![CDATA["<P>Please pay in <b><u>cash</u></b> or <b><u>EPS</u></b> at any Circle K, VanGO<br>Convenience Stores or U select.</P>"]]></textFieldExpression>
					</textField>
					<staticText>
						<reportElement x="21" y="38" width="239" height="67" uuid="7cd9ad43-e99c-4f81-8660-178e5e91d892">
							<property name="com.jaspersoft.studio.unit.height" value="px"/>
