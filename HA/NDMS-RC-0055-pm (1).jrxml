							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["<P>可於7-Eleven以<b><u>現金</u></b>繳付。</P>"]]></textFieldExpression>
					</textField>
					<textField>
