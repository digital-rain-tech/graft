					<staticText>
						<reportElement x="21" y="10" width="239" height="21" uuid="da0d53d4-883e-4737-acd2-2cf4bdb790f0"/>
						<textElement>
							<font fontName="SansSerif" size="7.5"/>
							<paragraph lineSpacing="Proportional" lineSpacingSize="0.8"/>
						</textElement>
						<text><![CDATA[Rent/licence fee and other charges shall be payable in advance on
the first day of every calendar month.]]></text>
					</staticText>
					<staticText>
						<reportElement x="21" y="59" width="239" height="21" uuid="b9502bd5-4189-4284-9794-8876410a44ea">
							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement>
							<font fontName="SansSerif" size="7.5"/>
							<paragraph lineSpacing="Proportional" lineSpacingSize="0.8"/>
						</textElement>
						<text><![CDATA[Payment should not be made to any persons other than the stated
payment methods in this monthly statement.]]></text>
					</staticText>
					<staticText>
						<reportElement x="21" y="30" width="239" height="35" uuid="11de1be5-2b43-40f1-9f25-1b760bcac8dd">
							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement>
							<font fontName="SansSerif" size="7.5"/>
							<paragraph lineSpacing="Proportional" lineSpacingSize="0.8"/>
						</textElement>
						<text><![CDATA[No matter whether Landlord demanded formally or not, to avoid
any levy of interest as stipulated in the Tenancy Agreement/
Licence, please pay within 14 days of the due date.]]></text>
					</staticText>
					<staticText>
						<reportElement x="21" y="79" width="239" height="41" uuid="fb098ba8-0a38-4858-8ef5-f28437274e92">
							<property name="com.jaspersoft.studio.unit.y" value="px"/>
							<property name="com.jaspersoft.studio.unit.height" value="px"/>
						</reportElement>
						<textElement>
							<font fontName="SansSerif" size="7.5"/>
							<paragraph lineSpacing="Proportional" lineSpacingSize="0.8"/>
						</textElement>
						<text><![CDATA[If you have paid the rent due for payment shown in the monthly
statement or you have any enquiries on the monthly statement,
please contact our estate office or property management
companies.]]></text>
					</staticText>
				</frame>
				<frame>
