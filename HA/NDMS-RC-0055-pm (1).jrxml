							<font fontName="Arial Unicode MS" size="8.5" isBold="true"/>
						</textElement>
						<textFieldExpression><![CDATA["注意事項"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="107" width="259" height="12" uuid="2ef3bcfd-4365-4ec2-ba13-efd7a3034605">
							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement markup="none">
							<font fontName="Arial Unicode MS" size="8.5" isBold="true"/>
						</textElement>
						<textFieldExpression><![CDATA["屋邨繳費處 (可接受現金或劃線支票)"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="14" y="117" width="245" height="11" uuid="b7fa14f7-2c5e-4443-ba44-16f8df44fdc4">
