  end 
  END as ITEM_AMT
FROM SPX_MTH_STMT_DTL dtl
where 
MTH_STMT_KEY = $P{MTH_STMT_KEY} and 
MTH_STMT_ITEM_PAGE_NUM = 5 
and MTH_STMT_ITEM_SCTN_NUM < 980
and exists(select 1 from SPX_MTH_STMT where rpt_id='NDMS-RC-0055' and MTH_STMT_KEY = dtl.MTH_STMT_KEY)
 order by dtl.MTH_STMT_ITEM_SCTN_NUM, 
 dtl.MTH_STMT_ITEM_BGN_DATE
  ,dtl.MTH_STMT_ITEM_PRIOR_NUM
 ,ITEM_NAME ASC]]>
		</queryString>
		<field name="MTH_STMT_KEY" class="java.math.BigDecimal">
			<property name="com.jaspersoft.studio.field.label" value="MTH_STMT_KEY"/>
		</field>
		<field name="MTH_STMT_ITEM_SCTN_NUM" class="java.math.BigDecimal">
			<property name="com.jaspersoft.studio.field.label" value="MTH_STMT_ITEM_SCTN_NUM"/>
		</field>
		<field name="MTH_STMT_ITEM_CATG_CODE" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="MTH_STMT_ITEM_CATG_CODE"/>
		</field>
		<field name="MTH_STMT_ITEM_CODE" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="MTH_STMT_ITEM_CODE"/>
		</field>
		<field name="MTH_STMT_ITEM_BGN_DATE" class="java.sql.Timestamp">
			<property name="com.jaspersoft.studio.field.label" value="MTH_STMT_ITEM_BGN_DATE"/>
		</field>
		<field name="MTH_STMT_ITEM_END_DATE" class="java.sql.Timestamp">
			<property name="com.jaspersoft.studio.field.label" value="MTH_STMT_ITEM_END_DATE"/>
		</field>
		<field name="MTH_STMT_ITEM_PRIOR_NUM" class="java.math.BigDecimal">
			<property name="com.jaspersoft.studio.field.label" value="MTH_STMT_ITEM_PRIOR_NUM"/>
		</field>
		<field name="MTH_STMT_ITEM_PAGE_NUM" class="java.math.BigDecimal">
			<property name="com.jaspersoft.studio.field.label" value="MTH_STMT_ITEM_PAGE_NUM"/>
		</field>
		<field name="ITEM_NAME" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="ITEM_NAME"/>
		</field>
		<field name="ITEM_PERIOD" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="ITEM_PERIOD"/>
		</field>
		<field name="MTH_STMT_ITEM_AMT" class="java.math.BigDecimal">
			<property name="com.jaspersoft.studio.field.label" value="MTH_STMT_ITEM_AMT"/>
		</field>
		<field name="MTH_STMT_ITEM_CR_CODE" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="MTH_STMT_ITEM_CR_CODE"/>
		</field>
		<field name="ITEM_AMT" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="ITEM_AMT"/>
		</field>
	</subDataset>
	<parameter name="MTH_STMT_KEY" class="java.lang.String"/>
	<parameter name="HA_LOGO" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="WATERMARK_CHI" class="java.lang.String" isForPrompting="false"/>
	<parameter name="WATERMARK_ENG" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[SELECT 
'C:'
                || stmt.COST_CTR_CODE
                || ' '
                || stmt.BSNS_ACTV_CODE AS burstkey
, stmt.MTH_STMT_KEY
, stmt.TNCY_AGRMT_KEY
, stmt.COST_CTR_CODE
, stmt.BSNS_ACTV_CODE 
, stmt.TNT_PPS_CODE
, stmt.MTH_STMT_DUE_AMT
, stmt.MTH_STMT_CHI_RMK_TEXT_1
, stmt.MTH_STMT_CHI_RMK_TEXT_2
, stmt.MTH_STMT_ENG_RMK_TEXT_1
, stmt.MTH_STMT_ENG_RMK_TEXT_2
, stmt.MTH_STMT_PAGE_CNT
, PKG_SPX_MRRS.FMT_CODE_ADDR(stmt.hse_stck_code_addr) AS CODE_ADDR
, to_char(stmt.MTH_STMT_ISS_DATE, 'dd/mm/yyyy') as MTH_STMT_ISS_DATE_DIS
, to_char(stmt.MTH_STMT_DUE_DATE, 'dd/mm/yyyy') as MTH_STMT_DUE_DATE_DIS
, substr(stmt.MTH_STMT_BRCD_TEXT,2,2)as HA_Code
, substr(stmt.MTH_STMT_BRCD_TEXT,4,2) as BILL_TYPE
, PKG_CM_BAR_CODE.Code128B(substr(stmt.MTH_STMT_BRCD_TEXT,1,25)) as BAR_CODE
, substr(stmt.MTH_STMT_BRCD_TEXT,1,25) as BAR2_CODE
, substr(stmt.HSE_STCK_PRMS_ENG_ADDR_1 || ' ' || 
  stmt.HSE_STCK_PRMS_ENG_ADDR_2 || ' ' || 
  stmt.HSE_STCK_PRMS_ENG_ADDR_3 || ' ' ||
  stmt.HSE_STCK_PRMS_ENG_ADDR_4 || ' ' ||
  stmt.HSE_STCK_PRMS_ENG_ADDR_5,1,120) as CUST_ENG_ADDR
, stmt.HSE_STCK_PRMS_CHI_ADDR_1 ||  
  stmt.HSE_STCK_PRMS_CHI_ADDR_2 ||
  stmt.HSE_STCK_PRMS_CHI_ADDR_3 ||
  stmt.HSE_STCK_PRMS_CHI_ADDR_4 ||
  stmt.HSE_STCK_PRMS_CHI_ADDR_5 as CUST_CHI_ADDR
, stmt.CUST_CHI_NAME_1 || ' ' || 
  stmt.CUST_CHI_NAME_2 || ' ' || 
  stmt.CUST_CHI_NAME_3 || ' ' || 
  stmt.CUST_CHI_NAME_4 || ' ' || 
  stmt.CUST_CHI_NAME_5 as CUST_CHI_NAME  
, substr(stmt.CUST_ENG_NAME_1 
        || decode(stmt.CUST_ENG_NAME_2, null, null, ', ' || stmt.CUST_ENG_NAME_2) 
        || decode(stmt.CUST_ENG_NAME_3, null, null, ', ' || stmt.CUST_ENG_NAME_3) 
        || decode(stmt.CUST_ENG_NAME_4, null, null, ', ' || stmt.CUST_ENG_NAME_4)
        || decode(stmt.CUST_ENG_NAME_5, null, null, ', ' || stmt.CUST_ENG_NAME_5), 1, 70) as CUST_ENG_NAME   
, stmt.BILL_CHI_ADDR_4 || ' ' ||
  stmt.BILL_CHI_ADDR_3 || ' ' ||
  stmt.BILL_CHI_ADDR_2 || ' ' ||
  stmt.BILL_CHI_ADDR_1 as BILL_CHI_ADDR
, stmt.BILL_ENG_ADDR_1 || ' ' ||
  stmt.BILL_ENG_ADDR_2 as BILL_ENG_ADDR_FST
, stmt.BILL_ENG_ADDR_3 || ' ' ||
  stmt.BILL_ENG_ADDR_4 as BILL_ENG_ADDR_SCD   
FROM SPX_MTH_STMT stmt 
WHERE stmt.MTH_STMT_KEY = $P{MTH_STMT_KEY} 
 and rpt_id='NDMS-RC-0055']]>
	</queryString>
