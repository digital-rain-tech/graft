							<font fontName="Arial Unicode MS" size="8"/>
						</textElement>
						<textFieldExpression><![CDATA["使用支援「轉數快」二維碼繳交香港房屋委員會帳單的銀行手機應用程式，掃描此月結單上的「轉數快」二維碼進行繳費。"]]></textFieldExpression>
					</textField>
				</frame>
