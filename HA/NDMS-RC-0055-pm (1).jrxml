						<textElement markup="html">
							<font fontName="SansSerif" size="7.5"/>
							<paragraph lineSpacing="Proportional" lineSpacingSize="0.9"/>
						</textElement>
						<textFieldExpression><![CDATA["You can pay in <b><u>cash or by crossed cheque </u></b>at any estate shroff offices<br>during the rent collection service hours."]]></textFieldExpression>
					</textField>
