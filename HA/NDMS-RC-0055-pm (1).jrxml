						</textElement>
						<textFieldExpression><![CDATA["Rejected Payment by Returned Cheques/Delinquent Autopay"]]></textFieldExpression>
					</textField>
					<staticText>
						<reportElement x="0" y="10" width="260" height="21" uuid="bf1c9957-d1c9-46fd-aa03-419b9f7f8ba4"/>
