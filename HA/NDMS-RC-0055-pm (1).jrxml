						<textElement verticalAlignment="Middle" markup="html">
							<font fontName="SansSerif" size="7.5"/>
						</textElement>
						<textFieldExpression><![CDATA["Through PPS by Internet at web site : <u>www.ppshk.com</u>"]]></textFieldExpression>
					</textField>
					<textField>
						<reportElement x="0" y="41" width="21" height="12" uuid="903b99c9-859a-47f9-9625-ec7d350fa6f1"/>
