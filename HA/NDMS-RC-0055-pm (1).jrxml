						<textFieldExpression><![CDATA["7-Eleven(Accept Cash Only)"]]></textFieldExpression>
					</textField>
					<staticText>
						<reportElement x="21" y="69" width="239" height="42" uuid="037d71b1-3005-42d0-91ef-9e22ae04d33a">
