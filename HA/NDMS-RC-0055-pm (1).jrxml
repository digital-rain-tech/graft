						</reportElement>
						<textElement>
							<font fontName="SansSerif" size="7.5"/>
							<paragraph lineSpacing="Proportional" lineSpacingSize="0.8"/>
						</textElement>
						<text><![CDATA[Simply present the monthly statement when making payment.
Please check carefully and ensure details printed on the receipt
are correct. Retain the receipt or make a photocopy of it, if
required, and the monthly statement as the record of payment for
checking.]]></text>
					</staticText>
